# ── Variables de entorno requeridas para el formulario de cotización ──────────
# Copiar este archivo como .env y completar con los valores reales.
# NUNCA commitear el archivo .env con valores reales.

# API key de Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email de origen para los envíos (debe estar verificado en Resend)
RESEND_FROM=cotizaciones@prg.cl

# Email interno del equipo PRG que recibe las notificaciones de cotización
CONTACT_EMAIL=equipo@prg.cl
