---
const capabilities = [
  {
    name: 'Impresión',
    desc: 'Offset, digital y UV. Alta resolución y fidelidad de color para cualquier tiraje.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>`,
  },
  {
    name: 'Corte',
    desc: 'Troquelado, corte CNC y láser en papel, cartón, vinilo y materiales rígidos.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z" /></svg>`,
  },
  {
    name: 'Grabado',
    desc: 'Grabado láser de precisión sobre madera, metal, acrílico y plástico.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>`,
  },
  {
    name: 'Terminaciones',
    desc: 'Laminado, barniz UV, hot stamping, relieve y troquelado especial.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>`,
  },
  {
    name: 'Múltiples Materiales',
    desc: 'Papel, cartón, vinilo, PVC, tela, metal, madera, acrílico y más.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>`,
  },
  {
    name: 'Aplicación',
    desc: 'Instalación profesional de vinilos, señalética y brandeo vehicular.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`,
  },
];
---

<section data-gpu-fix class="py-24 bg-brand-black">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <div>
        <span class="text-xs font-semibold uppercase tracking-widest text-brand-orange">Capacidades técnicas</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-white mb-6">
          Impresión, corte, grabado<br />y terminación en un solo lugar
        </h2>
        <p class="text-gray-400 leading-relaxed mb-8">
          Contamos con tecnologías y equipo humano especializado capaces de plasmar
          en cualquier tipo de objeto y material el mensaje o imagen que quieres
          entregar. Estamos siempre disponibles para asesorarte y recomendarte
          la solución óptima para tu proyecto.
        </p>
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 px-6 py-3 bg-brand-orange-text text-white font-semibold rounded-md hover:bg-brand-orange-text-hover transition-colors"
        >
          <span class="leading-none">Cotiza tu proyecto</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
        {capabilities.map((cap) => (
          <div data-gpu-fix class="flex flex-col p-5 rounded-xl bg-white/5 border border-white/10 hover:border-brand-orange/30 transition-colors">
            <div class="text-brand-orange mb-3">
              <Fragment set:html={cap.icon} />
            </div>
            <h3 class="text-white font-semibold text-sm mb-1.5">{cap.name}</h3>
            <p class="text-gray-400 text-xs leading-relaxed">{cap.desc}</p>
          </div>
        ))}
      </div>

    </div>

  </div>
</section>
