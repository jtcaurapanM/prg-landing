---
---

<section data-gpu-fix class="py-24 bg-brand-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">

      <span class="text-xs font-semibold uppercase tracking-widest text-brand-orange-text">Cotización</span>
      <h2 class="mt-4 text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-black leading-tight">
        ¿Listo para tu próximo<br />proyecto de impresión?
      </h2>
      <p class="mt-5 text-gray-500 leading-relaxed max-w-xl mx-auto">
        Cuéntanos tu necesidad y te respondemos en menos de 24 horas hábiles
        con una propuesta a medida. Sin costo ni compromiso.
      </p>

      <div class="mt-10 flex items-center justify-center">
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 px-8 py-4 bg-brand-orange-text text-white font-bold rounded-md hover:bg-brand-orange-text-hover transition-colors text-base"
        >
          Solicitar cotización
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="mt-12 grid grid-cols-3 gap-6 max-w-lg mx-auto">
        {[
          { value: '24h', label: 'Tiempo de respuesta' },
          { value: 'FSC', label: 'Certificación vigente' },
          { value: '14+', label: 'Años de experiencia' },
        ].map((stat) => (
          <div class="text-center">
            <div class="text-2xl font-bold text-brand-orange">{stat.value}</div>
            <div class="text-xs text-gray-600 mt-1 uppercase tracking-wide">{stat.label}</div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
