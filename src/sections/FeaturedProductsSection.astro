---
import ProductCard from '../components/catalog/ProductCard.astro';
import { products } from '../data/products';

const featured = products.filter((p) => p.featured).slice(0, 6);
---

<section data-gpu-fix class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-12 gap-4">
      <div>
        <span class="text-xs font-semibold uppercase tracking-widest text-brand-orange-text">Productos destacados</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-brand-black">Lo más solicitado</h2>
      </div>
      <a
        href="/catalogo"
        class="inline-flex items-center gap-2 text-sm font-semibold text-brand-orange-text hover:text-brand-orange-text-hover transition-colors whitespace-nowrap"
      >
        <span class="leading-none">Ver catálogo completo</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {featured.map((product) => (
        <ProductCard product={product} />
      ))}
    </div>

  </div>
</section>
