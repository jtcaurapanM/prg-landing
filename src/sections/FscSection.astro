---

---

<section data-gpu-fix class="py-24 bg-brand-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-stretch">
      <!-- Content -->
      <div>
        <div
          class="flex w-fit items-baseline gap-2 bg-green-50 border border-green-200 rounded-full px-4 py-2 mb-6"
        >
          <span class="block w-2 h-2 rounded-full bg-green-500 shrink-0 mb-px"></span>
          <span
            class="block text-xs font-semibold text-green-700 uppercase tracking-wide leading-none"
            >Certificación vigente</span
          >
        </div>

        <h2
          class="text-3xl sm:text-4xl font-bold text-brand-black mb-6 leading-tight"
        >
          Cuando imprimes con PRG,<br />
          <span class="text-brand-orange"
            >tu empresa también comunica responsabilidad</span
          >
        </h2>

        <p class="text-gray-600 leading-relaxed mb-6">
          La certificación FSC (Forest Stewardship Council) garantiza que los
          materiales que utilizamos provienen de bosques gestionados de forma
          responsable, verificados a través de una <strong
            >cadena de custodia forestal auditada</strong
          >.
        </p>

        <p class="text-gray-600 leading-relaxed mb-8">
          No es un sello decorativo. Es una auditoría real que cubre cada
          eslabón de nuestra cadena de suministro, desde el proveedor de papel
          hasta el producto final que llega a tus manos. Muchas empresas exigen
          esta certificación a sus proveedores como parte de sus políticas de
          compra responsable.
        </p>

        <!-- Certificate number -->
        <div
          data-gpu-fix
          class="inline-flex items-center gap-4 bg-white border border-gray-200 rounded-xl px-6 py-4"
        >
          <div>
            <div class="text-xs text-gray-600 uppercase tracking-widest mb-0.5">
              Número de certificado
            </div>
            <div class="text-xl font-bold text-brand-black">FSC C143583</div>
          </div>
          <div class="w-px h-10 bg-gray-200"></div>
          <div>
            <div class="text-xs text-gray-600 uppercase tracking-widest mb-0.5">
              Estado
            </div>
            <div
              class="text-sm font-bold text-green-700 flex items-center gap-1.5"
            >
              <span class="block w-2 h-2 rounded-full bg-green-500 shrink-0 mb-px"></span>
              <span class="block leading-none">Vigente</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Visual panel: SVG unificado en todos los dispositivos.
           En mobile el aspect-ratio A4 define la altura; en desktop (lg+)
           se elimina para que el panel llene la altura del grid. -->
      <div class="flex flex-col h-full">
        <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm h-full">
          <div class="relative w-full bg-white aspect-[595/842] lg:aspect-auto lg:h-full">
            <object
              data="/Certificado-FSC-2023.svg"
              type="image/svg+xml"
              class="block w-full h-full pointer-events-none"
              aria-hidden="true"
            ></object>
            <!-- Overlay: captura clicks (object tiene su propio browsing context) -->
            <button
              data-cert-open
              class="absolute inset-0 cursor-zoom-in group"
              aria-label="Ver certificado FSC C143583 ampliado"
            >
              <!-- Mobile: siempre visible · Desktop: aparece al hover -->
              <span class="absolute bottom-3 right-3 flex items-center gap-1.5 bg-black/50 text-white text-xs font-medium px-3 py-1.5 rounded-full pointer-events-none transition-opacity lg:opacity-0 lg:group-hover:opacity-100">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
                Ampliar
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Lightbox nativo (<dialog>) — sin dependencias externas -->
<dialog
  id="fsc-cert-dialog"
  aria-label="Certificado FSC C143583 ampliado"
  aria-modal="true"
>
  <div class="flex items-center justify-center w-full h-full p-4 sm:p-8">
    <div class="cert-panel relative w-full max-w-xl bg-white rounded-2xl overflow-hidden shadow-2xl flex flex-col" style="max-height: 90svh">
      <!-- Cerrar -->
      <button
        data-cert-close
        class="absolute top-3 right-3 z-10 w-9 h-9 flex items-center justify-center rounded-full bg-black/30 text-white hover:bg-black/60 transition-colors"
        aria-label="Cerrar"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      <!-- SVG: ocupa el espacio disponible; viewBox escala para caber (sin corte) -->
      <div class="flex-1 min-h-0">
        <object
          data="/Certificado-FSC-2023.svg"
          type="image/svg+xml"
          class="block w-full h-full pointer-events-none"
          aria-label="Certificado FSC C143583 — PRG Inversiones"
        ></object>
      </div>
      <!-- Footer: siempre visible en la parte inferior -->
      <div class="shrink-0 px-5 py-4 border-t border-gray-100 flex items-center justify-between gap-4 bg-white">
        <div>
          <p class="text-sm font-semibold text-brand-black">Certificado FSC C143583</p>
          <p class="text-xs text-gray-600 mt-0.5">PRG Inversiones</p>
        </div>
        <a
          href="/Certificado-FSC-2023.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 inline-flex items-center gap-1.5 px-4 py-2 bg-brand-black text-white text-xs font-semibold rounded-md hover:bg-brand-black-dark transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Descargar PDF
        </a>
      </div>
    </div>
  </div>
</dialog>

<script>
  // AbortController scoped to each page load: prevents listener accumulation
  // across View Transitions navigations.
  let _fscCtrl: AbortController | null = null;

  function initFscLightbox() {
    _fscCtrl?.abort();
    _fscCtrl = new AbortController();
    const { signal } = _fscCtrl;

    const dialog = document.getElementById("fsc-cert-dialog") as HTMLDialogElement | null;
    if (!dialog) return;

    function closeFscDialog() {
      const panel = dialog!.querySelector<HTMLElement>(".cert-panel");
      if (!panel) { dialog!.close(); return; }
      dialog!.classList.remove("is-open");
      dialog!.classList.add("is-closing");
      let done = false;
      const finish = () => {
        if (done) return;
        done = true;
        dialog!.classList.remove("is-closing");
        dialog!.close();
      };
      panel.addEventListener("animationend", finish, { once: true });
      // Fallback: si animationend no dispara (prefers-reduced-motion, GPU off…)
      setTimeout(finish, 250);
    }

    document.querySelectorAll("[data-cert-open]").forEach((btn) => {
      btn.addEventListener("click", () => {
        if (!dialog!.open) {
          dialog!.showModal();
          // rAF needed: Safari doesn't fire CSS animations on [open] children;
          // adding the class one frame later ensures the animation triggers.
          requestAnimationFrame(() => dialog!.classList.add("is-open"));
        }
      }, { signal });
    });

    dialog.querySelector("[data-cert-close]")?.addEventListener("click", closeFscDialog, { signal });

    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) closeFscDialog();
    }, { signal });

    // Captura Escape del navegador para animar el cierre
    dialog.addEventListener("cancel", (e) => {
      e.preventDefault();
      closeFscDialog();
    }, { signal });
  }

  document.addEventListener("astro:page-load", initFscLightbox);
</script>
