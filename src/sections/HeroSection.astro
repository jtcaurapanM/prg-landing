---

---

<section
  class="relative flex items-center overflow-hidden bg-[#101820]"
  style="min-height: 92svh; min-height: 92dvh;"
>
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1562774053-701939374585?w=1600&q=80&fm=webp"
      alt="Producción industrial de impresión"
      width="1600"
      height="900"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="w-full h-full object-cover opacity-25"
    />
    <div
      class="absolute inset-0 bg-gradient-to-r from-[#101820]/90 via-[#101820]/70 to-transparent"
    >
    </div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="max-w-2xl">
      <!-- Badge FSC -->
      <!-- Usar flex+w-fit en lugar de inline-flex: evita el bug de alineación
           vertical de Safari donde inline-flex + items-center + leading-none
           no centra correctamente los flex items. -->
      <!-- isolation: isolate contiene la capa GPU del animate-pulse
           evitando que Safari filtre el texto de capas vecinas -->
      <div
        class="flex w-fit items-baseline gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 mb-8 isolate"
      >
        <span
          class="block w-2 h-2 rounded-full bg-green-400 animate-pulse shrink-0 mb-px"
        ></span>
        <span class="block text-sm text-white/80 font-medium leading-none"
          >Certificación FSC C143583 vigente</span
        >
      </div>

      <!-- Headline -->
      <h1
        class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6"
      >
        Comunicación visual
        <span class="block text-[#F4622A]">industrial y sostenible</span>
      </h1>

      <!-- Subhead -->
      <p class="text-lg text-white/70 leading-relaxed mb-10 max-w-xl">
        Desde 2011 innovamos continuamente para resolver las necesidades de
        comunicación visual de tu empresa: impresión, corte, grabado y terminación
        en cualquier soporte, con insumos de cadena de custodia forestal certificada.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/contacto"
          class="inline-flex items-center justify-center px-8 py-4 bg-[#F4622A] text-white font-bold rounded-md hover:bg-[#d9521f] transition-colors text-base"
        >
          Solicitar cotización
        </a>
        <a
          href="/catalogo"
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-md hover:border-white hover:bg-white/10 transition-colors text-base"
        >
          <span class="leading-none">Ver catálogo</span>
          <svg
            class="ml-2 w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Stats -->
      <div class="mt-16 grid grid-cols-3 gap-8 max-w-md">
        <div>
          <div class="text-3xl font-bold text-white">14+</div>
          <div class="text-xs text-white/50 mt-1 uppercase tracking-wide">
            Años en el mercado
          </div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white">4</div>
          <div class="text-xs text-white/50 mt-1 uppercase tracking-wide">
            Líneas de negocio
          </div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[#F4622A]">FSC</div>
          <div class="text-xs text-white/50 mt-1 uppercase tracking-wide">
            Certificado
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
