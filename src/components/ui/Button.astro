---
interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { href, variant = 'primary', size = 'md', class: className = '' } = Astro.props;

const base = 'inline-flex items-center justify-center font-semibold rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-brand-orange focus:ring-offset-2';

const variants = {
  primary: 'bg-brand-orange-text text-white hover:bg-brand-orange-text-hover',
  outline: 'border-2 border-brand-orange-text text-brand-orange-text hover:bg-brand-orange-text hover:text-white',
  ghost: 'text-brand-black hover:text-brand-orange',
};

const sizes = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-7 py-3.5 text-base',
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button class={classes} type="submit">
    <slot />
  </button>
)}
