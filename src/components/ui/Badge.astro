---
interface Props {
  text: string;
  variant?: 'orange' | 'dark' | 'gray' | 'fsc';
}
const { text, variant = 'orange' } = Astro.props;

const styles = {
  orange: 'bg-brand-orange/10 text-brand-orange-text border border-brand-orange/20',
  dark: 'bg-brand-black text-white',
  gray: 'bg-gray-100 text-gray-600',
  fsc: 'bg-green-50 text-green-700 border border-green-200',
};
---

<span class={`inline-flex items-center px-2.5 py-0.5 rounded text-xs font-semibold uppercase tracking-wide ${styles[variant]}`}>
  {text}
</span>
