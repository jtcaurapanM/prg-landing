---
import { CATEGORY_LABELS } from "../data/categories";

const categoryEntries = Object.entries(CATEGORY_LABELS) as [string, string][];
const pathname = Astro.url.pathname;

const navLinks = [
  { href: "/",         label: "Inicio"   },
  { href: "/catalogo", label: "Catálogo" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/contacto", label: "Contacto" },
];

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<!-- Mobile overlay -->
<div
  id="mobile-overlay"
  transition:persist
  class="fixed inset-0 z-40 bg-black/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
></div>

<!-- Header -->
<header
  id="navbar"
  transition:persist
  class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 transition-shadow duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-2">

      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img src="/logoPRG.svg" alt="PRG Inversiones" class="h-18 w-auto" loading="eager" />
      </a>

      <!-- Nav desktop -->
      <nav class="hidden md:flex items-center gap-1">

        <!-- Inicio -->
        <a
          href="/"
          data-nav-link
          class={[
            "relative px-4 py-2 text-sm font-medium rounded-md transition-colors duration-200",
            isActive("/") ? "text-[#F4622A]" : "text-gray-600 hover:text-[#101820] hover:bg-gray-50",
          ].join(" ")}
          aria-current={isActive("/") ? "page" : "false"}
        >
          Inicio
          <span data-nav-indicator style={isActive("/") ? "" : "display:none"}
            class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-[2px] bg-[#F4622A] rounded-full" />
        </a>

        <!-- Catálogo con dropdown -->
        <div class="relative group">
          <a
            href="/catalogo"
            data-nav-link
            class={[
              "relative flex items-center gap-1 px-4 py-2 text-sm font-medium rounded-md transition-colors duration-200",
              isActive("/catalogo") ? "text-[#F4622A]" : "text-gray-600 hover:text-[#101820] hover:bg-gray-50",
            ].join(" ")}
            aria-current={isActive("/catalogo") ? "page" : "false"}
          >
            Catálogo
            <svg class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
            <span data-nav-indicator style={isActive("/catalogo") ? "" : "display:none"}
              class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-[2px] bg-[#F4622A] rounded-full" />
          </a>

          <div class="absolute top-full left-0 pt-1 z-50 min-w-[210px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-opacity duration-150">
            <div class="bg-white rounded-xl border border-gray-100 shadow-xl overflow-hidden py-1.5">
              <a href="/catalogo" class="flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-[#101820] hover:bg-gray-50 border-b border-gray-50">
                Todos los productos
              </a>
              {categoryEntries.map(([slug, label]) => (
                <a
                  href={`/catalogo?categoria=${slug}`}
                  class="flex items-center gap-2.5 px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-[#F4622A] transition-colors"
                >
                  <span class="w-1 h-1 rounded-full bg-[#F4622A] shrink-0" />
                  {label}
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Nosotros y Contacto -->
        {navLinks.filter(({ href }) => href !== "/" && href !== "/catalogo").map(({ href, label }) => (
          <a
            href={href}
            data-nav-link
            class={[
              "relative px-4 py-2 text-sm font-medium rounded-md transition-colors duration-200",
              isActive(href) ? "text-[#F4622A]" : "text-gray-600 hover:text-[#101820] hover:bg-gray-50",
            ].join(" ")}
            aria-current={isActive(href) ? "page" : "false"}
          >
            {label}
            <span data-nav-indicator style={isActive(href) ? "" : "display:none"}
              class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-[2px] bg-[#F4622A] rounded-full" />
          </a>
        ))}
      </nav>

      <!-- CTA desktop -->
      <a
        href="/contacto"
        class="hidden md:inline-flex items-center px-4 py-2 bg-[#F4622A] text-white text-sm font-semibold rounded-md hover:bg-[#d9521f] transition-colors"
      >
        Cotizar ahora
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden relative z-50 w-9 h-9 flex items-center justify-center rounded-md text-gray-600 hover:text-[#F4622A] transition-colors"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out bg-white border-t border-gray-100"
  >
    <nav class="px-4 pt-3 pb-5 flex flex-col gap-1">

      <!-- Inicio -->
      {navLinks.filter(({ href }) => href === "/").map(({ href, label }) => (
        <a
          href={href}
          data-mobile-nav-link
          class={[
            "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors duration-200",
            isActive(href) ? "bg-[#F4622A]/8 text-[#F4622A] font-semibold" : "text-gray-700 hover:bg-gray-50 hover:text-[#101820]",
          ].join(" ")}
          aria-current={isActive(href) ? "page" : undefined}
        >
          <span data-mobile-dot class={isActive(href) ? "w-1.5 h-1.5 rounded-full bg-[#F4622A] shrink-0" : "hidden"} />
          {label}
        </a>
      ))}

      <!-- Catálogo con submenu expandible -->
      <div>
        <div class="flex items-stretch rounded-lg overflow-hidden">
          <a
            href="/catalogo"
            data-mobile-catalog-link
            class={[
              "flex-1 flex items-center gap-3 px-4 py-3 text-sm font-medium transition-colors duration-200",
              isActive("/catalogo") ? "bg-[#F4622A]/8 text-[#F4622A] font-semibold" : "text-gray-700 hover:bg-gray-50 hover:text-[#101820]",
            ].join(" ")}
            aria-current={isActive("/catalogo") ? "page" : undefined}
          >
            <span data-mobile-dot class={isActive("/catalogo") ? "w-1.5 h-1.5 rounded-full bg-[#F4622A] shrink-0" : "hidden"} />
            Catálogo
          </a>
          <button
            id="catalog-mobile-toggle"
            data-mobile-catalog-toggle
            aria-label="Ver categorías"
            aria-expanded="false"
            class={[
              "flex items-center justify-center px-3 border-l transition-colors duration-200",
              isActive("/catalogo")
                ? "border-[#F4622A]/20 text-[#F4622A] bg-[#F4622A]/8"
                : "border-gray-100 text-gray-400 hover:text-[#F4622A] hover:bg-gray-50",
            ].join(" ")}
          >
            <svg id="catalog-mobile-chevron" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        </div>

        <div id="catalog-mobile-submenu" class="hidden pl-3 pt-1 pb-1 flex flex-col gap-0.5">
          {categoryEntries.map(([slug, label]) => (
            <a
              href={`/catalogo?categoria=${slug}`}
              class="flex items-center gap-2.5 px-4 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-50 hover:text-[#F4622A] transition-colors"
            >
              <span class="w-1 h-1 rounded-full bg-gray-300 shrink-0" />
              {label}
            </a>
          ))}
        </div>
      </div>

      <!-- Nosotros y Contacto -->
      {navLinks.filter(({ href }) => href !== "/" && href !== "/catalogo").map(({ href, label }) => (
        <a
          href={href}
          data-mobile-nav-link
          class={[
            "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors duration-200",
            isActive(href) ? "bg-[#F4622A]/8 text-[#F4622A] font-semibold" : "text-gray-700 hover:bg-gray-50 hover:text-[#101820]",
          ].join(" ")}
          aria-current={isActive(href) ? "page" : undefined}
        >
          <span data-mobile-dot class={isActive(href) ? "w-1.5 h-1.5 rounded-full bg-[#F4622A] shrink-0" : "hidden"} />
          {label}
        </a>
      ))}

      <div class="mt-2 pt-3 border-t border-gray-100">
        <a
          href="/contacto"
          class="flex items-center justify-center px-4 py-3 bg-[#F4622A] text-white text-sm font-bold rounded-lg hover:bg-[#d9521f] transition-colors"
        >
          Cotizar ahora
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const getEl = (id: string) => document.getElementById(id)!;

  // ── Estado del menú ────────────────────────────────────────────────────────
  let menuOpen = false;

  function openMenu() {
    menuOpen = true;
    const menu    = getEl("mobile-menu");
    const overlay = getEl("mobile-overlay");
    menu.style.maxHeight = menu.scrollHeight + "px";
    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-100");
    getEl("icon-open").classList.add("hidden");
    getEl("icon-close").classList.remove("hidden");
    getEl("mobile-menu-btn").setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    menuOpen = false;
    const menu    = getEl("mobile-menu");
    const overlay = getEl("mobile-overlay");
    menu.style.maxHeight = "0px";
    overlay.classList.add("opacity-0", "pointer-events-none");
    overlay.classList.remove("opacity-100");
    getEl("icon-open").classList.remove("hidden");
    getEl("icon-close").classList.add("hidden");
    getEl("mobile-menu-btn").setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  // ── Active state móvil ────────────────────────────────────────────────────
  function updateMobileNavActive() {
    const currentPath = window.location.pathname;

    const catalogLink   = document.querySelector<HTMLAnchorElement>("[data-mobile-catalog-link]");
    const catalogToggle = document.querySelector<HTMLElement>("[data-mobile-catalog-toggle]");
    const isCatalogActive = currentPath.startsWith("/catalogo");

    if (catalogLink) {
      catalogLink.classList.toggle("bg-[#F4622A]/8",   isCatalogActive);
      catalogLink.classList.toggle("text-[#F4622A]",   isCatalogActive);
      catalogLink.classList.toggle("font-semibold",    isCatalogActive);
      catalogLink.classList.toggle("text-gray-700",   !isCatalogActive);
      catalogLink.setAttribute("aria-current", isCatalogActive ? "page" : "false");
      const dot = catalogLink.querySelector<HTMLElement>("[data-mobile-dot]");
      if (dot) dot.className = isCatalogActive ? "w-1.5 h-1.5 rounded-full bg-[#F4622A] shrink-0" : "hidden";
    }

    if (catalogToggle) {
      catalogToggle.classList.toggle("border-[#F4622A]/20",  isCatalogActive);
      catalogToggle.classList.toggle("text-[#F4622A]",       isCatalogActive);
      catalogToggle.classList.toggle("bg-[#F4622A]/8",       isCatalogActive);
      catalogToggle.classList.toggle("border-gray-100",     !isCatalogActive);
      catalogToggle.classList.toggle("text-gray-400",       !isCatalogActive);
    }

    document.querySelectorAll<HTMLAnchorElement>("[data-mobile-nav-link]").forEach((link) => {
      const href   = link.getAttribute("href") ?? "";
      const active = href === "/" ? currentPath === "/" : currentPath.startsWith(href);
      link.classList.toggle("bg-[#F4622A]/8",  active);
      link.classList.toggle("text-[#F4622A]",  active);
      link.classList.toggle("font-semibold",   active);
      link.classList.toggle("text-gray-700",  !active);
      link.setAttribute("aria-current", active ? "page" : "false");
      const dot = link.querySelector<HTMLElement>("[data-mobile-dot]");
      if (dot) dot.className = active ? "w-1.5 h-1.5 rounded-full bg-[#F4622A] shrink-0" : "hidden";
    });
  }

  // ── Submenu catálogo móvil ────────────────────────────────────────────────
  function initCatalogMobileSubmenu() {
    const toggle  = document.getElementById("catalog-mobile-toggle");
    const submenu = document.getElementById("catalog-mobile-submenu");
    const chevron = document.getElementById("catalog-mobile-chevron");
    if (!toggle || !submenu) return;

    const newToggle = toggle.cloneNode(true) as HTMLElement;
    toggle.replaceWith(newToggle);

    newToggle.addEventListener("click", () => {
      const isOpen = !submenu.classList.contains("hidden");
      submenu.classList.toggle("hidden", isOpen);
      chevron?.classList.toggle("rotate-180", !isOpen);
      newToggle.setAttribute("aria-expanded", String(!isOpen));
      const mobileMenu = document.getElementById("mobile-menu");
      if (mobileMenu) mobileMenu.style.maxHeight = mobileMenu.scrollHeight + "px";
    });

    submenu.querySelectorAll("a").forEach((link) =>
      link.addEventListener("click", () => {
        submenu.classList.add("hidden");
        chevron?.classList.remove("rotate-180");
        newToggle.setAttribute("aria-expanded", "false");
      })
    );
  }

  // ── Mobile menu init ──────────────────────────────────────────────────────
  function initMobileMenu() {
    const btn     = getEl("mobile-menu-btn");
    const overlay = getEl("mobile-overlay");
    const menu    = getEl("mobile-menu");

    const newBtn = btn.cloneNode(true) as HTMLElement;
    btn.replaceWith(newBtn);
    const newOverlay = overlay.cloneNode(true) as HTMLElement;
    overlay.replaceWith(newOverlay);

    newBtn.addEventListener("click", () => menuOpen ? closeMenu() : openMenu());
    newOverlay.addEventListener("click", closeMenu);
    menu.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeMenu));

    window.addEventListener("resize", () => {
      if (menuOpen) getEl("mobile-menu").style.maxHeight = getEl("mobile-menu").scrollHeight + "px";
      if (window.innerWidth >= 768) closeMenu();
    });
  }

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menuOpen) closeMenu();
  });

  // Cerrar menú al navegar
  document.addEventListener("astro:before-swap", closeMenu);

  document.addEventListener("astro:page-load", () => {
    initMobileMenu();
    initCatalogMobileSubmenu();
    updateMobileNavActive();

    // Active state desktop
    const currentPath = window.location.pathname;
    document.querySelectorAll("[data-nav-link]").forEach((el) => {
      const link   = el as HTMLAnchorElement;
      const href   = link.getAttribute("href") ?? "";
      const active = href === "/" ? currentPath === "/" : currentPath.startsWith(href);
      link.setAttribute("aria-current", active ? "page" : "false");
      link.classList.toggle("text-[#F4622A]", active);
      link.classList.toggle("text-gray-600", !active);
      const indicator = link.querySelector("[data-nav-indicator]") as HTMLElement | null;
      if (indicator) indicator.style.display = active ? "block" : "none";
    });
  });
</script>
