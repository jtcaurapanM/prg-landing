---
import { CATEGORY_LABELS } from "../data/categories";

const categoryEntries = Object.entries(CATEGORY_LABELS) as [string, string][];
const pathname = Astro.url.pathname;

const navLinks = [
  { href: "/",         label: "Inicio"   },
  { href: "/catalogo", label: "Catálogo" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/contacto", label: "Contacto" },
];

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<!-- Header -->
<header
  id="navbar"
  transition:persist
  class="sticky top-0 z-50 bg-white border-b border-black/[0.06] transition-[transform,box-shadow] duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-2">

      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img src="/logoPRG.svg" alt="PRG Inversiones" class="h-18 w-auto" loading="eager" />
      </a>

      <!-- Nav desktop -->
      <nav class="hidden md:flex items-center gap-1">

        <!-- Inicio -->
        <a
          href="/"
          data-nav-link
          class:list={[
            "relative px-4 py-2 text-sm font-medium rounded-md transition-colors duration-200",
            isActive("/") ? "text-brand-orange-text" : "text-gray-600 hover:text-brand-black hover:bg-gray-50",
          ]}
          aria-current={isActive("/") ? "page" : undefined}
        >
          Inicio
          <span data-nav-indicator style={isActive("/") ? "" : "display:none"}
            class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-[2px] bg-brand-orange rounded-full" />
        </a>

        <!-- Catalogo con dropdown -->
        <div class="relative group" data-catalog-group>
          <a
            href="/catalogo"
            data-nav-link
            class:list={[
              "relative flex items-center gap-1 px-4 py-2 text-sm font-medium rounded-md transition-colors duration-200",
              isActive("/catalogo") ? "text-brand-orange-text" : "text-gray-600 hover:text-brand-black hover:bg-gray-50",
            ]}
            aria-current={isActive("/catalogo") ? "page" : undefined}
          >
            Catálogo
            <svg class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
            <span data-nav-indicator style={isActive("/catalogo") ? "" : "display:none"}
              class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-[2px] bg-brand-orange rounded-full" />
          </a>

          <div data-catalog-dropdown class="absolute top-full left-0 pt-1 z-50 min-w-[210px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-opacity duration-150">
            <div class="bg-white rounded-xl border border-gray-100 shadow-xl overflow-hidden py-1.5">
              <a href="/catalogo" class="flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-brand-black hover:bg-gray-50 border-b border-gray-50">
                Todos los productos
              </a>
              {categoryEntries.map(([slug, label]) => (
                <a
                  href={`/catalogo?categoria=${slug}`}
                  class="flex items-center gap-2.5 px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-brand-orange-text transition-colors"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-brand-orange shrink-0" />
                  {label}
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Nosotros y Contacto -->
        {navLinks.filter(({ href }) => href !== "/" && href !== "/catalogo").map(({ href, label }) => (
          <a
            href={href}
            data-nav-link
            class:list={[
              "relative px-4 py-2 text-sm font-medium rounded-md transition-colors duration-200",
              isActive(href) ? "text-brand-orange-text" : "text-gray-600 hover:text-brand-black hover:bg-gray-50",
            ]}
            aria-current={isActive(href) ? "page" : undefined}
          >
            {label}
            <span data-nav-indicator style={isActive(href) ? "" : "display:none"}
              class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-[2px] bg-brand-orange rounded-full" />
          </a>
        ))}
      </nav>

      <!-- CTA desktop -->
      <button
        type="button"
        data-open-global-quote
        class="hidden md:inline-flex items-center px-4 py-2 bg-brand-orange-text text-white text-sm font-semibold rounded-md hover:bg-brand-orange-text-hover transition-colors"
      >
        Cotizar ahora
      </button>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden relative z-50 w-9 h-9 flex items-center justify-center rounded-md text-gray-600 hover:text-brand-orange-text transition-colors"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <span class="relative block w-5 h-5">
          <svg id="icon-open" class="absolute inset-0 transition-all duration-300 ease-in-out" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="absolute inset-0 transition-all duration-300 ease-in-out opacity-0 rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="md:hidden bg-white border-t border-gray-100"
    style="max-height:0;overflow:hidden;transition:max-height 320ms cubic-bezier(0.4,0,0.2,1)"
  >
    <nav class="px-4 pt-3 pb-5 flex flex-col gap-1">

      <!-- Inicio -->
      {navLinks.filter(({ href }) => href === "/").map(({ href, label }) => (
        <a
          href={href}
          data-mobile-nav-link
          class:list={[
            "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors duration-200",
            isActive(href) ? "bg-brand-orange/8 text-brand-orange-text font-semibold" : "text-gray-700 hover:bg-gray-50 hover:text-brand-black",
          ]}
          aria-current={isActive(href) ? "page" : undefined}
        >
          <span data-mobile-dot class={isActive(href) ? "w-1.5 h-1.5 rounded-full bg-brand-orange shrink-0" : "hidden"} />
          {label}
        </a>
      ))}

      <!-- Catálogo con submenu expandible -->
      <div>
        <div class="flex items-stretch rounded-lg overflow-hidden">
          <a
            href="/catalogo"
            data-mobile-catalog-link
            class:list={[
              "flex-1 flex items-center gap-3 px-4 py-3 text-sm font-medium transition-colors duration-200",
              isActive("/catalogo") ? "bg-brand-orange/8 text-brand-orange-text font-semibold" : "text-gray-700 hover:bg-gray-50 hover:text-brand-black",
            ]}
            aria-current={isActive("/catalogo") ? "page" : undefined}
          >
            <span data-mobile-dot class={isActive("/catalogo") ? "w-1.5 h-1.5 rounded-full bg-brand-orange shrink-0" : "hidden"} />
            Catálogo
          </a>
          <button
            id="catalog-mobile-toggle"
            data-mobile-catalog-toggle
            aria-label="Ver categorías"
            aria-expanded="false"
            class:list={[
              "flex items-center justify-center px-3 border-l transition-colors duration-200",
              isActive("/catalogo")
                ? "border-brand-orange/20 text-brand-orange-text bg-brand-orange/8"
                : "border-gray-100 text-gray-400 hover:text-brand-orange-text hover:bg-gray-50",
            ]}
          >
            <svg id="catalog-mobile-chevron" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        </div>

        <div id="catalog-mobile-submenu" class="overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out">
          <div class="pl-3 pt-1 pb-1 flex flex-col gap-0.5">
            {categoryEntries.map(([slug, label]) => (
              <a
                href={`/catalogo?categoria=${slug}`}
                class="flex items-center gap-2.5 px-4 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-50 hover:text-brand-orange-text transition-colors"
              >
                <span class="w-1 h-1 rounded-full bg-gray-300 shrink-0" />
                {label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Nosotros y Contacto -->
      {navLinks.filter(({ href }) => href !== "/" && href !== "/catalogo").map(({ href, label }) => (
        <a
          href={href}
          data-mobile-nav-link
          class:list={[
            "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors duration-200",
            isActive(href) ? "bg-brand-orange/8 text-brand-orange-text font-semibold" : "text-gray-700 hover:bg-gray-50 hover:text-brand-black",
          ]}
          aria-current={isActive(href) ? "page" : undefined}
        >
          <span data-mobile-dot class={isActive(href) ? "w-1.5 h-1.5 rounded-full bg-brand-orange shrink-0" : "hidden"} />
          {label}
        </a>
      ))}

      <div class="mt-2 pt-3 border-t border-gray-100">
        <button
          type="button"
          data-open-global-quote
          class="w-full flex items-center justify-center px-4 py-3 bg-brand-orange-text text-white text-sm font-bold rounded-lg hover:bg-brand-orange-text-hover transition-colors"
        >
          Cotizar ahora
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- Overlay para menú mobile: debe estar FUERA del <header> para no quedar
     dentro de su stacking context (z-50). Así el header siempre queda encima. -->
<div
  id="mobile-overlay"
  aria-hidden="true"
  class="md:hidden fixed inset-0 bg-black/50 z-40 opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<script>
  const getEl = (id: string) => document.getElementById(id)!;

  // ── Estado ────────────────────────────────────────────────────────────────
  let menuOpen = false;
  let resizeHandler: (() => void) | null = null;
  // AbortController por ciclo de página: limpia listeners sobre nodos persistidos
  // (el Navbar tiene transition:persist — los mismos nodos sobreviven a VT).
  let _navPageCtrl: AbortController | null = null;

  // ── Helpers de overlay ────────────────────────────────────────────────────
  function showOverlay() {
    const overlay = document.getElementById("mobile-overlay");
    if (!overlay) return;
    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-100");
  }

  function hideOverlay() {
    const overlay = document.getElementById("mobile-overlay");
    if (!overlay) return;
    overlay.classList.remove("opacity-100");
    overlay.classList.add("opacity-0", "pointer-events-none");
  }

  // ── Abrir / cerrar menú ───────────────────────────────────────────────────
  // Se usa dvh (dynamic viewport height) para que el menú no quede cortado
  // por la barra del navegador en iOS. El menú scrollea internamente cuando
  // el contenido supera el espacio disponible — esto elimina el cálculo
  // dinámico de altura al abrir/cerrar el submenu (fix del "buceo").
  function openMenu() {
    menuOpen = true;
    const menu       = getEl("mobile-menu");
    const navbarEl   = document.getElementById("navbar");
    const navH       = navbarEl ? navbarEl.offsetHeight : 72;
    // 100dvh = viewport dinámico (excluye barra del browser en iOS)
    menu.style.maxHeight  = `calc(100dvh - ${navH}px)`;
    menu.style.overflowY  = "auto";
    getEl("icon-open").classList.add("opacity-0", "-rotate-90");
    getEl("icon-close").classList.remove("opacity-0", "rotate-90");
    const menuBtn = getEl("mobile-menu-btn");
    menuBtn.setAttribute("aria-expanded", "true");
    menuBtn.setAttribute("aria-label", "Cerrar menú");
    document.body.style.overflow = "hidden";
    showOverlay();
  }

  function closeMenu() {
    menuOpen = false;
    const menu = getEl("mobile-menu");
    menu.style.maxHeight = "0px";
    // Volver a overflow:hidden después de la transición para que no se vea contenido
    menu.addEventListener("transitionend", () => {
      if (!menuOpen) menu.style.overflowY = "hidden";
    }, { once: true });
    getEl("icon-open").classList.remove("opacity-0", "-rotate-90");
    getEl("icon-close").classList.add("opacity-0", "rotate-90");
    const menuBtn2 = getEl("mobile-menu-btn");
    menuBtn2.setAttribute("aria-expanded", "false");
    menuBtn2.setAttribute("aria-label", "Abrir menú");
    document.body.style.overflow = "";
    hideOverlay();
    // Restaurar navbar visible al cerrar el menú
    document.getElementById("navbar")?.classList.remove("navbar-hidden");
  }

  // ── Active state móvil ────────────────────────────────────────────────────
  function updateMobileNavActive() {
    const currentPath = window.location.pathname;

    const catalogLink   = document.querySelector<HTMLAnchorElement>("[data-mobile-catalog-link]");
    const catalogToggle = document.querySelector<HTMLElement>("[data-mobile-catalog-toggle]");
    const isCatalogActive = currentPath.startsWith("/catalogo");

    if (catalogLink) {
      catalogLink.classList.toggle("bg-brand-orange/8",   isCatalogActive);
      catalogLink.classList.toggle("text-brand-orange-text",   isCatalogActive);
      catalogLink.classList.toggle("font-semibold",    isCatalogActive);
      catalogLink.classList.toggle("text-gray-700",   !isCatalogActive);
      if (isCatalogActive) { catalogLink.setAttribute("aria-current", "page"); } else { catalogLink.removeAttribute("aria-current"); }
      const dot = catalogLink.querySelector<HTMLElement>("[data-mobile-dot]");
      if (dot) dot.className = isCatalogActive ? "w-1.5 h-1.5 rounded-full bg-brand-orange shrink-0" : "hidden";
    }

    if (catalogToggle) {
      catalogToggle.classList.toggle("border-brand-orange/20",  isCatalogActive);
      catalogToggle.classList.toggle("text-brand-orange-text",       isCatalogActive);
      catalogToggle.classList.toggle("bg-brand-orange/8",       isCatalogActive);
      catalogToggle.classList.toggle("border-gray-100",     !isCatalogActive);
      catalogToggle.classList.toggle("text-gray-400",       !isCatalogActive);
    }

    document.querySelectorAll<HTMLAnchorElement>("[data-mobile-nav-link]").forEach((link) => {
      const href   = link.getAttribute("href") ?? "";
      const active = href === "/" ? currentPath === "/" : currentPath.startsWith(href);
      link.classList.toggle("bg-brand-orange/8",  active);
      link.classList.toggle("text-brand-orange-text",  active);
      link.classList.toggle("font-semibold",   active);
      link.classList.toggle("text-gray-700",  !active);
      if (active) { link.setAttribute("aria-current", "page"); } else { link.removeAttribute("aria-current"); }
      const dot = link.querySelector<HTMLElement>("[data-mobile-dot]");
      if (dot) dot.className = active ? "w-1.5 h-1.5 rounded-full bg-brand-orange shrink-0" : "hidden";
    });
  }

  // ── Submenu catálogo móvil ────────────────────────────────────────────────
  // IMPORTANTE: Ya NO recalculamos la altura del menú padre al abrir/cerrar el
  // submenu. El menú padre ahora usa overflow-y:auto con max-height basado en
  // dvh, por lo que el submenu se expande naturalmente dentro del scroll.
  function initCatalogMobileSubmenu(signal: AbortSignal) {
    const toggle    = document.getElementById("catalog-mobile-toggle");
    const submenuEl = document.getElementById("catalog-mobile-submenu");
    const chevron   = document.getElementById("catalog-mobile-chevron");
    if (!toggle || !submenuEl) return;

    const submenu: HTMLElement = submenuEl;
    const newToggle = toggle.cloneNode(true) as HTMLElement;
    toggle.replaceWith(newToggle);

    function openSubmenu() {
      void submenu.offsetHeight;
      submenu.style.maxHeight = submenu.scrollHeight + "px";
      chevron?.classList.add("rotate-180");
      newToggle.setAttribute("aria-expanded", "true");
    }

    function closeSubmenu() {
      submenu.style.maxHeight = "0px";
      chevron?.classList.remove("rotate-180");
      newToggle.setAttribute("aria-expanded", "false");
    }

    newToggle.addEventListener("click", () => {
      const isOpen = parseInt(submenu.style.maxHeight) > 0;
      isOpen ? closeSubmenu() : openSubmenu();
    });

    // { signal } evita acumulación sobre los mismos nodos persistidos por transition:persist
    submenu.querySelectorAll("a").forEach((link) =>
      link.addEventListener("click", closeSubmenu, { signal })
    );
  }

  // ── Mobile menu init ──────────────────────────────────────────────────────
  let outsideClickHandler: ((e: MouseEvent) => void) | null = null;

  function initMobileMenu(signal: AbortSignal) {
    const btn  = getEl("mobile-menu-btn");
    const menu = getEl("mobile-menu");

    const newBtn = btn.cloneNode(true) as HTMLElement;
    btn.replaceWith(newBtn);

    newBtn.addEventListener("click", () => menuOpen ? closeMenu() : openMenu());
    // { signal } evita que los mismos links acumulen closeMenu en cada navegación
    menu.querySelectorAll("a, [data-open-global-quote]").forEach((el) =>
      el.addEventListener("click", closeMenu, { signal })
    );

    // Cerrar al hacer click en el overlay
    const overlay = document.getElementById("mobile-overlay");
    if (overlay) {
      overlay.addEventListener("click", closeMenu, { signal });
    }

    // Cerrar al hacer click fuera del navbar
    if (outsideClickHandler) document.removeEventListener("click", outsideClickHandler);
    outsideClickHandler = (e: MouseEvent) => {
      const navbar = document.getElementById("navbar");
      if (menuOpen && navbar && !navbar.contains(e.target as Node)) closeMenu();
    };
    document.addEventListener("click", outsideClickHandler);

    if (resizeHandler) window.removeEventListener("resize", resizeHandler);
    resizeHandler = () => {
      if (menuOpen) {
        // Recalcular altura en cambio de orientación
        const navbarEl = document.getElementById("navbar");
        const navH = navbarEl ? navbarEl.offsetHeight : 72;
        getEl("mobile-menu").style.maxHeight = `calc(100dvh - ${navH}px)`;
      }
      if (window.innerWidth >= 768) closeMenu();
    };
    window.addEventListener("resize", resizeHandler);
  }

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menuOpen) closeMenu();
  });

  document.addEventListener("astro:before-swap", closeMenu);

  document.addEventListener("astro:page-load", () => {
    // Abortar ciclo anterior: limpia todos los listeners sobre nodos persistidos
    _navPageCtrl?.abort();
    _navPageCtrl = new AbortController();
    const { signal } = _navPageCtrl;

    document.body.style.overflow = "";
    initMobileMenu(signal);
    initCatalogMobileSubmenu(signal);
    updateMobileNavActive();

    // Active state desktop
    const currentPath = window.location.pathname;
    document.querySelectorAll("[data-nav-link]").forEach((el) => {
      const link   = el as HTMLAnchorElement;
      const href   = link.getAttribute("href") ?? "";
      const active = href === "/" ? currentPath === "/" : currentPath.startsWith(href);
      if (active) { link.setAttribute("aria-current", "page"); } else { link.removeAttribute("aria-current"); }
      link.classList.toggle("text-brand-orange-text", active);
      link.classList.toggle("text-gray-600", !active);
      const indicator = link.querySelector("[data-nav-indicator]") as HTMLElement | null;
      if (indicator) indicator.style.display = active ? "block" : "none";
    });

    // CB-06: Touch support para dropdown catálogo en tablets/touch devices.
    // { signal } evita acumulación sobre el mismo nodo persistido por transition:persist.
    const catalogGroup = document.querySelector('[data-catalog-group]') as HTMLElement | null;
    if (catalogGroup) {
      catalogGroup.addEventListener('touchstart', (e) => {
        const dropdown = catalogGroup.querySelector('[data-catalog-dropdown]') as HTMLElement | null;
        if (!dropdown) return;
        const isOpen = dropdown.classList.contains('touch-open');
        if (!isOpen) {
          e.preventDefault();
          document.querySelectorAll('[data-catalog-dropdown].touch-open').forEach((el) => {
            el.classList.remove('touch-open', 'opacity-100', 'visible');
            el.classList.add('opacity-0', 'invisible');
          });
          dropdown.classList.add('touch-open', 'opacity-100', 'visible');
          dropdown.classList.remove('opacity-0', 'invisible');
          const closeOnOutside = (ev: TouchEvent) => {
            if (!catalogGroup.contains(ev.target as Node)) {
              dropdown.classList.remove('touch-open', 'opacity-100', 'visible');
              dropdown.classList.add('opacity-0', 'invisible');
              document.removeEventListener('touchstart', closeOnOutside as EventListener);
            }
          };
          setTimeout(() => document.addEventListener('touchstart', closeOnOutside as EventListener), 0);
        }
      }, { passive: false, signal });
    }
  });
</script>