---
interface Props {
  productName?: string;
  compact?: boolean;
}

const { productName = '', compact = false } = Astro.props;
---

<!--
  Tailwind safelist (clases usadas sólo desde JS):
  border-red-400 ring-red-400 focus:ring-red-400
-->

<form id="quote-form" class="space-y-4" novalidate>
  <div class={compact ? 'grid grid-cols-1 sm:grid-cols-2 gap-4' : 'space-y-4'}>

    <!-- Nombre -->
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
        Nombre completo <span class="text-[#F4622A]">*</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="name"
        placeholder="Juan González"
        class="field-input w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition"
      />
      <p class="field-error hidden text-xs text-red-500 mt-1.5" aria-live="polite"></p>
    </div>

    <!-- Email -->
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
        Correo <span class="text-[#F4622A]">*</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        placeholder="juan@empresa.cl"
        class="field-input w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition"
      />
      <p class="field-error hidden text-xs text-red-500 mt-1.5" aria-live="polite"></p>
    </div>


{!compact && (
      <div>
        <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
          Teléfono <span class="text-gray-400 font-normal">(opcional)</span>
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          autocomplete="tel"
          placeholder="+56 9 0000 0000"
          class="w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition"
        />
      </div>
    )}
  </div>

  {!compact && (
    <div>
      <span class="block text-sm font-medium text-gray-700 mb-2">
        Línea de interés <span class="text-[#F4622A]">*</span>
        <span class="text-gray-400 font-normal">(puedes elegir varias)</span>
      </span>
      <div id="category-group" class="flex flex-wrap gap-2" role="group" aria-label="Línea de interés" aria-required="true">
        {[
          { value: 'papeleria-corporativa', label: 'Papelería corporativa' },
          { value: 'grandes-formatos',      label: 'Grandes formatos'      },
          { value: 'promocionales',          label: 'Regalos Promocionales'  },
          { value: 'packaging-etiquetas',    label: 'Packaging y etiquetas' },
        ].map(({ value, label }) => (
          <label class="category-chip inline-flex items-center gap-2 px-4 py-2 rounded-full border border-gray-200 bg-white text-sm font-medium text-gray-600 cursor-pointer select-none transition-colors hover:border-[#F4622A] hover:text-[#F4622A]">
            <input
              type="checkbox"
              name="category"
              value={value}
              class="sr-only peer"
            />
            <span class="w-3.5 h-3.5 shrink-0 rounded-sm border border-gray-300 peer-checked:bg-[#F4622A] peer-checked:border-[#F4622A] transition-colors flex items-center justify-center">
              <svg class="checkmark hidden w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </span>
            {label}
          </label>
        ))}
      </div>
      <p id="category-error" class="hidden text-xs text-red-500 mt-1.5" aria-live="polite">
        Selecciona al menos una línea de interés.
      </p>
    </div>
  )}

  {!compact && (
    <div>
      <label for="product-ref" class="block text-sm font-medium text-gray-700 mb-1">
        Producto de referencia <span class="text-gray-400 font-normal">(opcional)</span>
      </label>
      <input
        type="text"
        id="product-ref"
        name="productRef"
        value={productName}
        placeholder="Ej: Tarjetas de presentación, gigantografía..."
        class="w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition"
      />
    </div>
  )}

  {!compact && (
    <div>
      <label for="qty" class="block text-sm font-medium text-gray-700 mb-1">Cantidad aproximada</label>
      <select
        id="qty"
        name="quantity"
        class="w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition bg-white"
      >
        <option value="">No lo sé aún</option>
        <option value="1-50">1 – 50 unidades</option>
        <option value="51-200">51 – 200 unidades</option>
        <option value="201-1000">201 – 1.000 unidades</option>
        <option value="1000+">Más de 1.000 unidades</option>
      </select>
    </div>
  )}

  <!-- Mensaje -->
  <div>
    <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
      {compact ? 'Mensaje' : 'Descripción de tu necesidad'} <span class="text-[#F4622A]">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows={compact ? 3 : 5}
      maxlength="5000"
      placeholder={compact
        ? 'Cuéntanos en qué podemos ayudarte...'
        : 'Ej: Necesito 500 carpetas con logo corporativo para evento en junio. Necesitamos diseño incluido.'}
      class="field-input w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition resize-none"
    ></textarea>
    <p class="field-error hidden text-xs text-red-500 mt-1.5" aria-live="polite"></p>
  </div>

  <!-- Status messages -->
  <div id="form-success" class="hidden p-4 bg-green-50 border border-green-200 rounded-md">
    <p class="text-sm text-green-700 font-medium">¡Mensaje enviado! Te contactaremos en 24 horas hábiles.</p>
  </div>
  <div id="form-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-md">
    <p class="text-sm text-red-700 font-medium">Ocurrió un error. Por favor intenta nuevamente o contáctanos directamente.</p>
  </div>

  <button
    type="submit"
    id="form-submit"
    class="w-full flex items-center justify-center gap-2 px-6 py-3 bg-[#F4622A] text-white font-semibold rounded-md hover:bg-[#d9521f] transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
  >
    <span id="btn-text">Enviar cotización</span>
    <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
    </svg>
  </button>

  <p class="text-xs text-gray-400 text-center">No compartimos tu información con terceros.</p>
</form>

<script>
  type ValidatableInput = HTMLInputElement | HTMLTextAreaElement;

  // ── Reglas de validación ────────────────────────────────────────────────────
  const RULES: Record<string, (v: string) => string | null> = {
    name:    (v) => !v.trim()
      ? 'El nombre es obligatorio.'
      : v.trim().length < 2
        ? 'Ingresa al menos 2 caracteres.'
        : null,

    email:   (v) => {
      if (!v.trim()) return 'El email es obligatorio.';
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v.trim())) return 'Ingresa un email válido.';
      return null;
    },

    message: (v) => !v.trim()
      ? 'Describe tu necesidad para poder cotizarte.'
      : v.trim().length < 10
        ? 'Añade un poco más de detalle (mínimo 10 caracteres).'
        : null,
  };

  const VALID_CLS   = ['border-gray-200', 'focus:ring-[#F4622A]'];
  const INVALID_CLS = ['border-red-400',  'focus:ring-red-400'];

  // ── Helpers ─────────────────────────────────────────────────────────────────
  function getErrorEl(el: Element): HTMLElement | null {
    return el.parentElement?.querySelector('.field-error') ?? null;
  }

  function markInvalid(el: ValidatableInput, msg: string) {
    el.classList.remove(...VALID_CLS);
    el.classList.add(...INVALID_CLS);
    el.setAttribute('aria-invalid', 'true');
    const err = getErrorEl(el);
    if (err) { err.textContent = msg; err.classList.remove('hidden'); }
  }

  function markValid(el: ValidatableInput) {
    el.classList.remove(...INVALID_CLS);
    el.classList.add(...VALID_CLS);
    el.removeAttribute('aria-invalid');
    const err = getErrorEl(el);
    if (err) { err.textContent = ''; err.classList.add('hidden'); }
  }

  function validateInput(el: ValidatableInput): boolean {
    const rule = RULES[el.name];
    if (!rule) return true;
    const msg = rule(el.value);
    if (msg) { markInvalid(el, msg); return false; }
    markValid(el);
    return true;
  }

  // ── Chips de categoría ──────────────────────────────────────────────────────
  // Retorna la función validateCategories como closure para que initForm
  // la use directamente, sin pasar por window globals (BUG-04/05 fix)
  function initChips(): () => boolean {
    const categoryError = document.getElementById('category-error');

    function validateCategories(): boolean {
      const anyChecked = Array.from(
        document.querySelectorAll<HTMLInputElement>('input[name="category"]')
      ).some((cb) => cb.checked);

      if (categoryError) categoryError.classList.toggle('hidden', anyChecked);
      return anyChecked;
    }

    document.querySelectorAll<HTMLLabelElement>('.category-chip').forEach((chip) => {
      const checkbox  = chip.querySelector<HTMLInputElement>('input[type="checkbox"]')!;
      const checkmark = chip.querySelector<SVGElement>('.checkmark')!;

      function syncChip() {
        if (checkbox.checked) {
          chip.classList.add('border-[#F4622A]', 'text-[#F4622A]', 'bg-orange-50');
          chip.classList.remove('border-gray-200', 'text-gray-600', 'bg-white');
          checkmark?.classList.remove('hidden');
        } else {
          chip.classList.remove('border-[#F4622A]', 'text-[#F4622A]', 'bg-orange-50');
          chip.classList.add('border-gray-200', 'text-gray-600', 'bg-white');
          checkmark?.classList.add('hidden');
        }
        // Si ya hubo intento de envio, re-validar al cambiar
        if (categoryError && !categoryError.classList.contains('hidden')) {
          validateCategories();
        }
      }

      checkbox.addEventListener('change', syncChip);
      syncChip(); // estado inicial
    });

    // Retornar para que initForm la use como closure (no via window global)
    return validateCategories;
  }

  // ── Inicializacion ──────────────────────────────────────────────────────────
  function initForm(validateCategories: () => boolean) {
    const form       = document.getElementById('quote-form')     as HTMLFormElement | null;
    const submitBtn  = document.getElementById('form-submit')    as HTMLButtonElement | null;
    const btnText    = document.getElementById('btn-text') as HTMLElement | null;
    const btnSpinner = document.getElementById('btn-spinner') as HTMLElement | null;
    const successMsg = document.getElementById('form-success') as HTMLElement | null;
    const errorMsg   = document.getElementById('form-error') as HTMLElement | null;

    if (!form || !submitBtn || !btnText || !btnSpinner || !successMsg || !errorMsg) return;

    // Pre-fill producto desde URL param
    const productRef = form.querySelector<HTMLInputElement>('#product-ref');
    if (productRef) {
      const param = new URLSearchParams(window.location.search).get('producto');
      if (param) productRef.value = decodeURIComponent(param);
    }

    // Campos que admiten live validation (solo despues de un intento de envio o blur)
    const liveFields = new Set<string>();

    // Adjuntar listeners de blur e input a todos los campos validables
    form.querySelectorAll<ValidatableInput>('.field-input').forEach((el) => {
      el.addEventListener('blur', () => {
        if (RULES[el.name]) {
          liveFields.add(el.name);
          validateInput(el);
        }
      });

      el.addEventListener('input', () => {
        if (liveFields.has(el.name)) validateInput(el);
      });
    });

    // Submit handler
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      const inputs = Array.from(form.querySelectorAll<ValidatableInput>('.field-input'));
      let firstInvalid: ValidatableInput | null = null;
      let allValid = true;

      inputs.forEach((el) => {
        if (!RULES[el.name]) return;
        liveFields.add(el.name);
        const ok = validateInput(el);
        if (!ok && !firstInvalid) firstInvalid = el;
        if (!ok) allValid = false;
      });

      // Validar checkboxes de categoria usando la funcion closure (sin global)
      const categoriesValid = validateCategories();
      if (!categoriesValid) allValid = false;

      if (!allValid) {
        if (firstInvalid) {
          firstInvalid.focus();
        } else {
          document.getElementById('category-group')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        return;
      }

      submitBtn.disabled = true;
      btnText.textContent = 'Enviando...';
      btnSpinner.classList.remove('hidden');

      const formData = new FormData(form);
      const categories = formData.getAll('category') as string[];
      const data = {
        ...Object.fromEntries(formData.entries()),
        category: categories.join(','),
      };

      try {
        const res = await fetch('/api/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          successMsg.classList.remove('hidden');
          form.reset();
          liveFields.clear();
          inputs.forEach((el) => { if (RULES[el.name]) markValid(el); });
          document.getElementById('category-error')?.classList.add('hidden');
          // Re-sincronizar chips al hacer reset
          document.querySelectorAll<HTMLLabelElement>('.category-chip').forEach((chip) => {
            chip.classList.remove('border-[#F4622A]', 'text-[#F4622A]', 'bg-orange-50');
            chip.classList.add('border-gray-200', 'text-gray-600', 'bg-white');
            chip.querySelector<SVGElement>('.checkmark')?.classList.add('hidden');
          });
        } else {
          errorMsg.classList.remove('hidden');
        }
      } catch {
        errorMsg.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        btnText.textContent = 'Enviar cotizacion';
        btnSpinner.classList.add('hidden');
      }
    });
  }

  document.addEventListener('astro:page-load', () => {
    const validateCategories = initChips();
    initForm(validateCategories);
  });
</script>
