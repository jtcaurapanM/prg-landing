---
interface Props {
  productName?: string;
  compact?: boolean;
  dialogMode?: boolean;
}

const { productName = "", compact = false, dialogMode = false } = Astro.props;
---

<!-- ── FORM ──────────────────────────────────────────────────────────────── -->
<form id="quote-form" class={dialogMode ? "space-y-4" : "space-y-5"} novalidate>
  <!-- Honeypot: invisible para usuarios; bots lo completan automáticamente -->
  <div
    style="position:absolute;left:-9999px;width:0;height:0;overflow:hidden;"
    aria-hidden="true"
  >
    <label for="website">No completar este campo</label>
    <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
  </div>

  <!-- Row 1: Nombre + Email -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
        Nombre <span class="text-[#F4622A]">*</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="given-name"
        placeholder="Tu nombre"
        class="field-input w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A]/20 focus:border-[#F4622A] transition"
      />
      <p class="field-error hidden text-xs text-red-500 mt-1.5" aria-live="polite"></p>
    </div>
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
        Correo electrónico <span class="text-[#F4622A]">*</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        placeholder="tu@empresa.com"
        class="field-input w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A]/20 focus:border-[#F4622A] transition"
      />
      <p class="field-error hidden text-xs text-red-500 mt-1.5" aria-live="polite"></p>
    </div>
  </div>

  <!-- Row 2: Producto de referencia (full width) -->
  <div>
    <label for="product-ref" class="block text-sm font-medium text-gray-700 mb-1">
      Producto de referencia <span class="text-gray-400 font-normal">(opcional)</span>
    </label>
    <input
      type="text"
      id="product-ref"
      name="productRef"
      value={productName}
      placeholder="Ej: Tarjetas de presentación, gigantografía..."
      class="w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A]/20 focus:border-[#F4622A] transition"
    />
  </div>

  <!-- Row 3: Descripción (full width) -->
  <div>
    <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
      {compact ? "Mensaje" : "Descripción de tu necesidad"}
      <span class="text-[#F4622A]">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows={compact ? 3 : dialogMode ? 3 : 4}
      maxlength="5000"
      placeholder={compact
        ? "Cuéntanos en qué podemos ayudarte..."
        : "Ej: Necesito 500 carpetas con logo corporativo para evento en junio. Necesitamos diseño incluido."}
      class="field-input w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A]/20 focus:border-[#F4622A] transition resize-none"
    ></textarea>
    <div class="flex items-start justify-between mt-1 gap-2">
      <p class="field-error hidden text-xs text-red-500 leading-relaxed flex-1" aria-live="polite"></p>
      <p id="char-counter" class="text-xs text-gray-400 tabular-nums shrink-0 ml-auto">0 / 5.000</p>
    </div>
  </div>

  <!-- Error de servidor -->
  <div id="form-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-md">
    <p class="text-sm text-red-700 font-medium">
      Ocurrió un error. Por favor intenta nuevamente o contáctanos directamente.
    </p>
  </div>

  <!-- Botón de envío -->
  <button
    type="submit"
    id="form-submit"
    class="w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-[#F4622A] text-white font-semibold rounded-md hover:bg-[#d9521f] transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
  >
    <span id="btn-text">Enviar cotización</span>
    <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
    </svg>
  </button>

  <p class="text-xs text-gray-400 text-center">
    No compartimos tu información con terceros.
  </p>
</form>

<!-- ── PANEL DE ÉXITO ─────────────────────────────────────────────────────── -->
<div id="success-panel" class="hidden space-y-6" aria-live="polite" aria-atomic="true">
  <div class="text-center py-2">
    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
      </svg>
    </div>
    <h3 class="text-xl font-bold text-[#101820] mb-2">¡Solicitud enviada con éxito!</h3>
    <p class="text-gray-500 text-sm leading-relaxed">
      Te responderemos en menos de 24 horas hábiles.<br />
      También recibirás una copia por correo electrónico.
    </p>
  </div>

  <div id="success-summary" class="bg-[#F8F8F6] rounded-xl p-5 text-sm"></div>

  <div>
    <p class="text-sm font-semibold text-[#101820] mb-3">¿Qué sigue?</p>
    <div class="space-y-3">
      <div class="flex items-start gap-3">
        <span class="w-6 h-6 rounded-full bg-[#F4622A] text-white text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">1</span>
        <p class="text-sm text-gray-500">Revisamos los detalles de tu proyecto.</p>
      </div>
      <div class="flex items-start gap-3">
        <span class="w-6 h-6 rounded-full bg-[#F4622A] text-white text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">2</span>
        <p class="text-sm text-gray-500">Preparamos una propuesta a medida, sin costo ni compromiso.</p>
      </div>
      <div class="flex items-start gap-3">
        <span class="w-6 h-6 rounded-full bg-[#F4622A] text-white text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">3</span>
        <p class="text-sm text-gray-500">Recibirás nuestra respuesta por correo electrónico.</p>
      </div>
    </div>
  </div>

  <button
    type="button"
    id="btn-reset"
    class="w-full flex items-center justify-center px-6 py-3 border-2 border-[#101820] text-[#101820] font-semibold rounded-md hover:bg-[#101820] hover:text-white transition-colors"
  >
    Enviar otra cotización
  </button>
</div>

<script>
  type ValidatableInput = HTMLInputElement | HTMLTextAreaElement;

  // ── Reglas de validación ──────────────────────────────────────────────────────
  const RULES: Record<string, (v: string) => string | null> = {
    name: (v) =>
      !v.trim()
        ? "El nombre es obligatorio."
        : v.trim().length < 2
          ? "Ingresa al menos 2 caracteres."
          : null,

    email: (v) => {
      if (!v.trim()) return "El correo electrónico es obligatorio.";
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v.trim()))
        return "Ingresa un correo electrónico válido.";
      return null;
    },

    message: (v) =>
      !v.trim()
        ? "Describe tu necesidad para poder cotizarte."
        : v.trim().length < 10
          ? "Añade un poco más de detalle (mínimo 10 caracteres)."
          : null,
  };

  const VALID_CLS   = ["border-gray-200"];
  const INVALID_CLS = ["border-red-400"];

  // ── Helpers ───────────────────────────────────────────────────────────────────
  function getErrorEl(el: Element): HTMLElement | null {
    return el.parentElement?.querySelector(".field-error") ?? null;
  }

  function markInvalid(el: ValidatableInput, msg: string) {
    el.classList.remove(...VALID_CLS);
    el.classList.add(...INVALID_CLS);
    el.setAttribute("aria-invalid", "true");
    const err = getErrorEl(el);
    if (err) { err.textContent = msg; err.classList.remove("hidden"); }
  }

  function markValid(el: ValidatableInput) {
    el.classList.remove(...INVALID_CLS);
    el.classList.add(...VALID_CLS);
    el.removeAttribute("aria-invalid");
    const err = getErrorEl(el);
    if (err) { err.textContent = ""; err.classList.add("hidden"); }
  }

  function validateInput(el: ValidatableInput): boolean {
    const rule = RULES[el.name];
    if (!rule) return true;
    const msg = rule(el.value);
    if (msg) { markInvalid(el, msg); return false; }
    markValid(el);
    return true;
  }

  function escHtml(s: string): string {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  // ── Contador de caracteres ────────────────────────────────────────────────────
  function initCharCounter() {
    const textarea   = document.getElementById("message")      as HTMLTextAreaElement | null;
    const charCounter = document.getElementById("char-counter") as HTMLElement | null;
    if (!textarea || !charCounter) return;

    textarea.addEventListener("input", () => {
      const count = textarea.value.length;
      charCounter.textContent = `${count.toLocaleString("es-CL")} / 5.000`;
      charCounter.classList.toggle("text-orange-500", count > 4800 && count <= 5000);
      charCounter.classList.toggle("text-red-500",    count > 5000);
      charCounter.classList.toggle("text-gray-400",   count <= 4800);
    });
  }

  // ── Inicialización del formulario ─────────────────────────────────────────────
  function initForm() {
    const form         = document.getElementById("quote-form")   as HTMLFormElement   | null;
    const successPanel = document.getElementById("success-panel") as HTMLElement      | null;
    const successSummary = document.getElementById("success-summary") as HTMLElement  | null;
    const submitBtn    = document.getElementById("form-submit")   as HTMLButtonElement | null;
    const btnText      = document.getElementById("btn-text")      as HTMLElement      | null;
    const btnSpinner   = document.getElementById("btn-spinner")   as HTMLElement      | null;
    const errorMsg     = document.getElementById("form-error")    as HTMLElement      | null;
    const btnReset     = document.getElementById("btn-reset")     as HTMLButtonElement | null;

    if (!form || !submitBtn || !btnText || !btnSpinner || !errorMsg || !successPanel) return;

    // Pre-fill producto desde URL param (cuando viene del catálogo)
    const productRef = form.querySelector<HTMLInputElement>("#product-ref");
    if (productRef) {
      const param = new URLSearchParams(window.location.search).get("producto");
      if (param) productRef.value = decodeURIComponent(param);
    }

    const liveFields = new Set<string>();

    form.querySelectorAll<ValidatableInput>(".field-input").forEach((el) => {
      el.addEventListener("blur", () => {
        if (RULES[el.name]) { liveFields.add(el.name); validateInput(el); }
      });
      el.addEventListener("input", () => {
        if (liveFields.has(el.name)) validateInput(el);
      });
    });

    // ── Reset ─────────────────────────────────────────────────────────────────
    const safeForm = form;
    function resetForm() {
      safeForm.reset();
      liveFields.clear();
      safeForm.querySelectorAll<ValidatableInput>(".field-input").forEach((el) => {
        if (RULES[el.name]) markValid(el);
      });
      const counter = document.getElementById("char-counter");
      if (counter) counter.textContent = "0 / 5.000";
    }

    btnReset?.addEventListener("click", () => {
      successPanel.classList.add("hidden");
      form.classList.remove("hidden");
      resetForm();
      form.scrollIntoView({ behavior: "smooth", block: "nearest" });
    });

    // ── Submit ────────────────────────────────────────────────────────────────
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorMsg.classList.add("hidden");

      const inputs = Array.from(form.querySelectorAll<ValidatableInput>(".field-input"));
      let firstInvalid: ValidatableInput | null = null;
      let allValid = true;

      for (const el of inputs) {
        if (!RULES[el.name]) continue;
        liveFields.add(el.name);
        const ok = validateInput(el);
        if (!ok && firstInvalid === null) firstInvalid = el;
        if (!ok) allValid = false;
      }

      if (!allValid) {
        firstInvalid?.focus();
        return;
      }

      // Capturar datos para el resumen de éxito (antes del reset)
      const submittedName       = (form.querySelector<HTMLInputElement>("#name")?.value       ?? "").trim();
      const submittedEmail      = (form.querySelector<HTMLInputElement>("#email")?.value      ?? "").trim();
      const submittedProductRef = (form.querySelector<HTMLInputElement>("#product-ref")?.value ?? "").trim();

      submitBtn.disabled = true;
      btnText.textContent = "Enviando...";
      btnSpinner.classList.remove("hidden");

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const res = await fetch("/api/send", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          if (successSummary) {
            const rows: Array<{ label: string; value: string }> = [
              { label: "Contacto", value: submittedName },
              { label: "Correo",   value: submittedEmail },
              ...(submittedProductRef ? [{ label: "Producto", value: submittedProductRef }] : []),
            ].filter((r) => r.value.length > 0);

            successSummary.innerHTML = rows
              .map(
                (r, i) => `
                <div class="flex justify-between gap-4 py-2.5 ${i > 0 ? "border-t border-gray-200" : ""}">
                  <span class="text-gray-500 text-sm shrink-0">${escHtml(r.label)}</span>
                  <span class="text-[#101820] font-medium text-sm text-right break-all">${escHtml(r.value)}</span>
                </div>`,
              )
              .join("");
          }

          form.classList.add("hidden");
          successPanel.classList.remove("hidden");
          successPanel.scrollIntoView({ behavior: "smooth", block: "nearest" });
          resetForm();
        } else {
          errorMsg.classList.remove("hidden");
        }
      } catch {
        errorMsg.classList.remove("hidden");
      } finally {
        submitBtn.disabled = false;
        btnText.textContent = "Enviar cotización";
        btnSpinner.classList.add("hidden");
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    initCharCounter();
    initForm();
  });
</script>

<style>
  /*
   * Estado inválido via CSS (aria-invalid) para evitar que Safari recalcule
   * el scroll cuando JS modifica clases en campos con foco activo.
   */
  .field-input[aria-invalid="true"] {
    border-color: #f87171; /* red-400 */
  }
  .field-input[aria-invalid="true"]:focus {
    border-color: #f87171;
    --tw-ring-color: rgba(248, 113, 113, 0.2);
  }
</style>
