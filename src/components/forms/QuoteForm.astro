---
interface Props {
  productName?: string;
  compact?: boolean;
}

const { productName = '', compact = false } = Astro.props;
---

<form
  id="quote-form"
  class="space-y-4"
  novalidate
>
  <div class={compact ? 'grid grid-cols-1 sm:grid-cols-2 gap-4' : 'space-y-4'}>
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nombre completo <span class="text-[#F4622A]">*</span></label>
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="name"
        placeholder="Juan González"
        class="w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition"
      />
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email corporativo <span class="text-[#F4622A]">*</span></label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        placeholder="juan@empresa.cl"
        class="w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition"
      />
    </div>

    <div>
      <label for="company" class="block text-sm font-medium text-gray-700 mb-1">Empresa <span class="text-[#F4622A]">*</span></label>
      <input
        type="text"
        id="company"
        name="company"
        required
        autocomplete="organization"
        placeholder="Nombre de tu empresa"
        class="w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition"
      />
    </div>

    {!compact && (
      <div>
        <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Teléfono <span class="text-gray-400 font-normal">(opcional)</span></label>
        <input
          type="tel"
          id="phone"
          name="phone"
          autocomplete="tel"
          placeholder="+56 9 0000 0000"
          class="w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition"
        />
      </div>
    )}
  </div>

  {!compact && (
    <div>
      <label for="category" class="block text-sm font-medium text-gray-700 mb-1">Línea de interés</label>
      <select
        id="category"
        name="category"
        class="w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition bg-white"
      >
        <option value="">Selecciona una línea</option>
        <option value="papeleria-corporativa">Papelería Corporativa</option>
        <option value="grandes-formatos">Grandes Formatos</option>
        <option value="promocionales">Promocionales</option>
        <option value="packaging-etiquetas">Packaging y Etiquetas</option>
      </select>
    </div>
  )}

  {!compact && (
    <div>
      <label for="product-ref" class="block text-sm font-medium text-gray-700 mb-1">Producto de referencia <span class="text-gray-400 font-normal">(opcional)</span></label>
      <input
        type="text"
        id="product-ref"
        name="productRef"
        value={productName}
        placeholder="Ej: Tarjetas de presentación, gigantografía..."
        class="w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition"
      />
    </div>
  )}

  {!compact && (
    <div>
      <label for="qty" class="block text-sm font-medium text-gray-700 mb-1">Cantidad aproximada</label>
      <select
        id="qty"
        name="quantity"
        class="w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition bg-white"
      >
        <option value="">No lo sé aún</option>
        <option value="1-50">1 – 50 unidades</option>
        <option value="51-200">51 – 200 unidades</option>
        <option value="201-1000">201 – 1.000 unidades</option>
        <option value="1000+">Más de 1.000 unidades</option>
      </select>
    </div>
  )}

  <div>
    <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
      {compact ? 'Mensaje' : 'Descripción de tu necesidad'} <span class="text-[#F4622A]">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows={compact ? 3 : 5}
      placeholder={compact ? 'Cuéntanos en qué podemos ayudarte...' : 'Ej: Necesito 500 carpetas con logo corporativo para evento en junio. Necesitamos diseño incluido.'}
      class="w-full px-4 py-2.5 border border-gray-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#F4622A] focus:border-transparent transition resize-none"
    ></textarea>
  </div>

  <!-- Status messages -->
  <div id="form-success" class="hidden p-4 bg-green-50 border border-green-200 rounded-md">
    <p class="text-sm text-green-700 font-medium">¡Mensaje enviado! Te contactaremos en 24 horas hábiles.</p>
  </div>
  <div id="form-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-md">
    <p class="text-sm text-red-700 font-medium">Ocurrió un error. Por favor intenta nuevamente o contáctanos por WhatsApp.</p>
  </div>

  <button
    type="submit"
    id="form-submit"
    class="w-full flex items-center justify-center gap-2 px-6 py-3 bg-[#F4622A] text-white font-semibold rounded-md hover:bg-[#d9521f] transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
  >
    <span id="btn-text">Enviar cotización</span>
    <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
    </svg>
  </button>

  <p class="text-xs text-gray-400 text-center">No compartimos tu información con terceros.</p>
</form>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement;
  const submitBtn = document.getElementById('form-submit') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text')!;
  const btnSpinner = document.getElementById('btn-spinner')!;
  const successMsg = document.getElementById('form-success')!;
  const errorMsg = document.getElementById('form-error')!;

  // Pre-fill product from URL param
  const productRef = document.getElementById('product-ref') as HTMLInputElement | null;
  if (productRef) {
    const param = new URLSearchParams(window.location.search).get('producto');
    if (param) productRef.value = decodeURIComponent(param);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    submitBtn.disabled = true;
    btnText.textContent = 'Enviando...';
    btnSpinner.classList.remove('hidden');

    const data = Object.fromEntries(new FormData(form).entries());

    try {
      const res = await fetch('/api/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        successMsg.classList.remove('hidden');
        form.reset();
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnText.textContent = 'Enviar cotización';
      btnSpinner.classList.add('hidden');
    }
  });
</script>
