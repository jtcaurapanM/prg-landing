---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import QuoteForm from "../components/forms/QuoteForm.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description,
  ogImage = "/og-default.jpg",
  canonical = Astro.url.href,
} = Astro.props;

const siteUrl = "https://www.prg.cl/";
const fullTitle = title.includes("PRG") ? title : `${title} · PRG Inversiones`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, interactive-widget=resizes-visual"
    />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content="PRG Inversiones" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="theme-color" content="#FA4616" />
    <!-- Preload fuentes críticas en WOFF2 (formato óptimo generado con convert-fonts.sh) -->
    <link rel="preload" href="/fonts/Gotham-Medium.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Gotham-Bold.woff2"   as="font" type="font/woff2" crossorigin />
    <!-- Preconnect para imágenes externas: amortiza DNS + TCP + TLS antes del primer request -->
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />

    <ClientRouter />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "PRG Inversiones",
        "url": "https://prg.cl",
        "logo": "https://prg.cl/logoPRG.svg",
        "foundingDate": "2011",
        "description": "Soluciones de impresión y comunicación visual con certificación FSC C143583.",
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "sales",
          "availableLanguage": "Spanish"
        }
      }
    </script>
  </head>

  <body class="bg-white text-brand-black font-sans antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-brand-orange focus:text-white focus:font-semibold focus:rounded-md"
    >
      Saltar al contenido
    </a>
    <Navbar />

    <main id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer data-gpu-fix class="bg-brand-black text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div>
            <div class="font-bold text-xl mb-3">
              <span class="text-brand-orange">PRG</span> Inversiones
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">
              Desde 2011 resolvemos necesidades de comunicación visual con
              tecnología de impresión, corte, grabado y terminación, y el
              respaldo de la certificación FSC C143583.
            </p>
          </div>

          <div>
            <h3
              class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-4"
            >
              Servicios
            </h3>
            <ul class="space-y-2 text-sm text-gray-300">
              <li>
                <a
                  href="/catalogo?categoria=papeleria-corporativa"
                  class="block hover:text-white transition-colors"
                  >Papelería Corporativa</a
                >
              </li>
              <li>
                <a
                  href="/catalogo?categoria=grandes-formatos"
                  class="block hover:text-white transition-colors"
                  >Grandes Formatos</a
                >
              </li>
              <li>
                <a
                  href="/catalogo?categoria=promocionales"
                  class="block hover:text-white transition-colors"
                  >Regalos Promocionales</a
                >
              </li>
              <li>
                <a
                  href="/catalogo?categoria=packaging-etiquetas"
                  class="block hover:text-white transition-colors"
                  >Packaging y Etiquetas</a
                >
              </li>
            </ul>
          </div>

          <div>
            <h3
              class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-4"
            >
              Contacto
            </h3>
            <ul class="space-y-2 text-sm text-gray-300">
              <li>
                <a
                  href="/contacto"
                  class="block hover:text-white transition-colors"
                  >Formulario de cotización</a
                >
              </li>
              <li>
                <a
                  href="mailto:contacto@prg.cl"
                  class="block hover:text-white transition-colors"
                >
                  contacto@prg.cl
                </a>
              </li>
              <li>
                <a
                  href="/nosotros"
                  class="block hover:text-white transition-colors"
                  >Sobre PRG Inversiones</a
                >
              </li>
            </ul>
          </div>
        </div>

        <div
          class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4"
        >
          <p class="text-gray-500 text-xs">
            © {new Date().getFullYear()} Inversiones PRG SpA. Todos los derechos reservados.
          </p>
          <p class="text-gray-600 text-xs">Santiago, Chile · Fundada 2011</p>
        </div>
      </div>
    </footer>

    <!-- ── Dialog global de cotización (navbar CTA) ────────────────────────── -->
    <dialog id="global-quote-dialog" aria-modal="true" aria-labelledby="global-dialog-title">
      <div class="sticky top-0 z-10 flex items-center justify-between px-6 sm:px-8 py-4 bg-white border-b border-black/[0.06]">
        <div>
          <h2 id="global-dialog-title" class="font-bold text-brand-black text-base">Solicitar cotización</h2>
          <p class="text-xs text-gray-400 mt-0.5">Te respondemos a la brevedad</p>
        </div>
        <button
          type="button"
          id="global-quote-close"
          class="flex items-center justify-center w-8 h-8 rounded-full text-gray-400 hover:text-brand-black hover:bg-gray-100 transition-colors"
          aria-label="Cerrar formulario"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="px-6 sm:px-8 py-6">
        <QuoteForm dialogMode={true} />
        <p class="mt-5 text-center text-xs text-gray-400">
          ¿Prefieres escribir directo?
          <a href="mailto:contacto@prg.cl" class="text-brand-orange hover:underline font-medium">contacto@prg.cl</a>
        </p>
      </div>
    </dialog>

    <script>
      // ── Mobile auto-hide navbar ────────────────────────────────────────────
      let lastScrollY = window.scrollY;

      function handleScroll() {
        const navbar = document.getElementById("navbar");
        if (!navbar) return;

        const currentScrollY = window.scrollY;
        const delta = currentScrollY - lastScrollY;

        // Auto-hide solo en mobile (< 768px)
        if (window.matchMedia("(max-width: 767px)").matches) {
          const isMenuOpen =
            document.getElementById("mobile-menu-btn")?.getAttribute("aria-expanded") === "true";

          if (!isMenuOpen) {
            if (currentScrollY <= 60) {
              // Cerca del top: siempre visible
              navbar.classList.remove("navbar-hidden");
            } else if (delta > 6) {
              // Scrolleando hacia abajo con suficiente velocidad
              navbar.classList.add("navbar-hidden");
            } else if (delta < -4) {
              // Scrolleando hacia arriba
              navbar.classList.remove("navbar-hidden");
            }
          }
        } else {
          // Desktop: siempre visible
          navbar.classList.remove("navbar-hidden");
        }

        lastScrollY = currentScrollY;
      }

      window.addEventListener("scroll", handleScroll, { passive: true });

      // ── Dialog global de cotización ────────────────────────────────────────
      // Event delegation: corre una vez al cargar el módulo. Funciona con el
      // navbar que tiene transition:persist y persiste entre navegaciones.
      document.addEventListener("click", (e: MouseEvent) => {
        const btn = (e.target as Element).closest("[data-open-global-quote]");
        if (!btn) return;
        const dialog = document.getElementById("global-quote-dialog") as HTMLDialogElement | null;
        if (dialog && !dialog.open) {
          dialog.showModal();
          // rAF: Safari no dispara animaciones CSS en <dialog> al cambiar [open]
          requestAnimationFrame(() => dialog.classList.add("is-open"));
          document.body.style.overflow = "hidden";
        }
      });

      function closeGlobalDialog() {
        const dialog = document.getElementById("global-quote-dialog") as HTMLDialogElement | null;
        if (!dialog || !dialog.open) return;
        dialog.classList.remove("is-open");
        dialog.classList.add("is-closing");
        let done = false;
        const finish = () => {
          if (done) return;
          done = true;
          dialog.classList.remove("is-closing");
          dialog.close();
          document.body.style.overflow = "";
        };
        dialog.addEventListener("animationend", finish, { once: true });
        // Fallback: si animationend no dispara (prefers-reduced-motion, GPU off, etc.)
        setTimeout(finish, 250);
      }

      // ── Dirección de navegación ────────────────────────────────────────────
      // astro:before-preparation siempre es el primer evento del sistema de
      // navegación de Astro, garantizando que isBackNav esté listo cuando
      // astro:before-swap lo lee (evita la race condition con popstate).
      let isBackNav = false;
      document.addEventListener("astro:before-preparation", (e) => {
        isBackNav =
          (e as unknown as { navigationType: string }).navigationType ===
          "traverse";
      });

      // ── Product card transitions ───────────────────────────────────────────
      function setCardTransition(slug: string) {
        const card = document.querySelector(
          `[data-product-card][data-slug="${slug}"]`,
        );
        const imgEl = card?.querySelector(
          "[data-card-image]",
        ) as HTMLElement | null;
        const contentEl = card?.querySelector(
          "[data-card-content]",
        ) as HTMLElement | null;
        if (imgEl) imgEl.style.viewTransitionName = `product-img-${slug}`;
        if (contentEl)
          contentEl.style.viewTransitionName = `product-info-${slug}`;
      }

      function clearCardTransitions() {
        document
          .querySelectorAll("[data-card-image], [data-card-content]")
          .forEach((el) => {
            (el as HTMLElement).style.viewTransitionName = "";
          });
      }

      function initCardTransitions() {
        document.querySelectorAll("[data-product-card]").forEach((card) => {
          card.addEventListener("click", () => {
            const slug = (card as HTMLElement).dataset.slug ?? "";
            sessionStorage.setItem("lastProductSlug", slug);
            sessionStorage.setItem("catalogScrollY", window.scrollY.toString());
            setCardTransition(slug);
          });
        });
      }

      // ── Antes de swap: marcar dirección + cerrar dialog global ──────────
      document.addEventListener("astro:before-swap", () => {
        document.documentElement.dataset.navDirection = isBackNav
          ? "back"
          : "forward";
        isBackNav = false;
        const gDialog = document.getElementById("global-quote-dialog") as HTMLDialogElement | null;
        if (gDialog?.open) {
          gDialog.classList.remove("is-closing", "is-open");
          gDialog.close();
          document.body.style.overflow = "";
        }
      });

      // ── After swap: filtro catálogo ───────────────────────────────────────
      document.addEventListener("astro:after-swap", () => {
        const navDir = document.documentElement.dataset.navDirection;
        const filterCat = new URLSearchParams(window.location.search).get(
          "categoria",
        );

        if (navDir === "back") {
          document
            .querySelectorAll<HTMLElement>("[data-card-wrapper]")
            .forEach((wrapper) => {
              const show = !filterCat || wrapper.dataset.category === filterCat;
              wrapper.style.display = show ? "" : "none";
            });

          // En back no se activa el morph del elemento compartido:
          // al volver, el producto está en la parte superior del detalle y
          // la card puede estar en cualquier punto del grid. El morph produce
          // el efecto visual de "subida" que reporta el usuario porque anima
          // el elemento desde el top de la pantalla hacia abajo mientras el
          // scroll también cambia. Sin morph, Astro restaura el scroll desde
          // history.state de forma limpia con un simple fade.
          return;
        }

        // Navegación forward: activar morph del elemento compartido
        document
          .querySelectorAll<HTMLElement>("[data-card-wrapper]")
          .forEach((wrapper) => {
            const show = !filterCat || wrapper.dataset.category === filterCat;
            wrapper.style.display = show ? "" : "none";
          });

        const slug = sessionStorage.getItem("lastProductSlug");
        if (slug) setCardTransition(slug);
      });

      // ── Page load ─────────────────────────────────────────────────────────
      document.addEventListener("astro:page-load", () => {
        document.body.style.overflow = "";
        clearCardTransitions();
        // Resetear auto-hide al navegar: siempre mostrar navbar en página nueva
        document.getElementById("navbar")?.classList.remove("navbar-hidden");
        lastScrollY = window.scrollY;

        const prevNavDir = document.documentElement.dataset.navDirection;
        delete document.documentElement.dataset.navDirection;

        // Fallback de scroll para back nav: si Astro no restauró la posición
        // (edge cases: iOS Safari, primera visita sin history.state guardado),
        // la aplicamos manualmente desde sessionStorage.
        if (prevNavDir === "back") {
          const savedScrollY = parseInt(
            sessionStorage.getItem("catalogScrollY") ?? "0",
            10,
          );
          if (savedScrollY > 0 && window.scrollY === 0) {
            window.scrollTo({ top: savedScrollY, behavior: "instant" });
          }
          sessionStorage.removeItem("catalogScrollY");
        }

        // Actualizar CSS custom property con la altura real del navbar
        const navbar = document.getElementById("navbar");
        if (navbar) {
          document.documentElement.style.setProperty(
            "--navbar-height",
            navbar.offsetHeight + "px",
          );
        }

        const slugMatch = window.location.pathname.match(/\/catalogo\/([^/]+)/);
        if (slugMatch) sessionStorage.setItem("lastProductSlug", slugMatch[1]);

        handleScroll();
        initCardTransitions();

        // Inicializar botón de cierre y backdrop del dialog global
        const gDialog = document.getElementById("global-quote-dialog") as HTMLDialogElement | null;
        if (gDialog) {
          document.getElementById("global-quote-close")?.addEventListener("click", closeGlobalDialog);
          gDialog.addEventListener("click", (e: MouseEvent) => {
            if (e.target === gDialog) closeGlobalDialog();
          });
          gDialog.addEventListener("cancel", (e: Event) => {
            e.preventDefault();
            closeGlobalDialog();
          });
        }
      });
    </script>
  </body>
</html>
