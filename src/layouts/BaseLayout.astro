---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description,
  ogImage = "/og-default.jpg",
  canonical = Astro.url.href,
} = Astro.props;

const siteUrl  = "https://prg.cl";
const fullTitle = title.includes("PRG") ? title : `${title} · PRG Inversiones`;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={`${siteUrl}${ogImage}`} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="es_CL" />
    <meta property="og:site_name"   content="PRG Inversiones" />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${siteUrl}${ogImage}`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <ViewTransitions />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "PRG Inversiones",
        "url": "https://prg.cl",
        "logo": "https://prg.cl/logoPRG.svg",
        "foundingDate": "2011",
        "description": "Soluciones de impresión y comunicación visual con certificación FSC C143583.",
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "sales",
          "availableLanguage": "Spanish"
        }
      }
    </script>
  </head>

  <body class="bg-white text-[#101820] font-sans antialiased">

    <Navbar />

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-[#101820] text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

          <div>
            <div class="font-bold text-xl mb-3">
              <span class="text-[#F4622A]">PRG</span> Inversiones
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">
              Desde 2011 resolvemos necesidades de comunicación visual con
              tecnología de impresión, corte, grabado y terminación, y el
              respaldo de la certificación FSC C143583.
            </p>
            <div class="mt-4 inline-flex items-center gap-2 bg-white/10 rounded-md px-3 py-2">
              <span class="text-xs text-gray-300 font-medium">Certificación FSC</span>
              <span class="text-xs text-[#F4622A] font-bold">C143583</span>
            </div>
          </div>

          <div>
            <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-4">
              Servicios
            </h3>
            <ul class="space-y-2 text-sm text-gray-300">
              <li><a href="/catalogo?categoria=papeleria-corporativa" class="hover:text-white transition-colors">Papelería Corporativa</a></li>
              <li><a href="/catalogo?categoria=grandes-formatos"      class="hover:text-white transition-colors">Grandes Formatos</a></li>
              <li><a href="/catalogo?categoria=promocionales"         class="hover:text-white transition-colors">Regalos Promocionales</a></li>
              <li><a href="/catalogo?categoria=packaging-etiquetas"   class="hover:text-white transition-colors">Packaging y Etiquetas</a></li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-4">
              Contacto
            </h3>
            <ul class="space-y-2 text-sm text-gray-300">
              <li><a href="/contacto"  class="hover:text-white transition-colors">Formulario de cotización</a></li>
              <li><a href="/nosotros"  class="hover:text-white transition-colors">Sobre PRG Inversiones</a></li>
            </ul>
          </div>

        </div>

        <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
          <p class="text-gray-500 text-xs">
            © {new Date().getFullYear()} Inversiones PRG SpA. Todos los derechos reservados.
          </p>
          <p class="text-gray-600 text-xs">Santiago, Chile · Fundada 2011</p>
        </div>
      </div>
    </footer>

    <!-- WhatsApp flotante -->
    <a
      href="https://wa.me/56900000000?text=Hola%2C%20me%20gustar%C3%ADa%20cotizar%20un%20producto."
      target="_blank"
      rel="noopener noreferrer"
      transition:persist
      class="fixed bottom-6 right-6 z-50 flex items-center gap-2 bg-[#25D366] text-white px-4 py-3 rounded-full shadow-lg hover:bg-[#1ebe5c] transition-colors text-sm font-semibold"
      aria-label="Contactar por WhatsApp"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
      </svg>
      WhatsApp
    </a>

    <script>
      const getEl = (id: string) => document.getElementById(id)!;

      // ── Scroll shadow ──────────────────────────────────────────────────────
      function handleScroll() {
        const navbar = getEl("navbar");
        if (window.scrollY > 20) {
          navbar.classList.add("shadow-md");
          navbar.classList.remove("border-gray-100");
        } else {
          navbar.classList.remove("shadow-md");
          navbar.classList.add("border-gray-100");
        }
      }

      window.addEventListener("scroll", handleScroll, { passive: true });

      // ── Dirección de navegación ────────────────────────────────────────────
      let isBackNav = false;
      window.addEventListener("popstate", () => { isBackNav = true; });

      // ── Product card transitions ───────────────────────────────────────────
      function setCardTransition(slug: string) {
        const card     = document.querySelector(`[data-product-card][data-slug="${slug}"]`);
        const imgEl    = card?.querySelector("[data-card-image]")   as HTMLElement | null;
        const contentEl = card?.querySelector("[data-card-content]") as HTMLElement | null;
        if (imgEl)     imgEl.style.viewTransitionName     = `product-img-${slug}`;
        if (contentEl) contentEl.style.viewTransitionName = `product-info-${slug}`;
      }

      function clearCardTransitions() {
        document.querySelectorAll("[data-card-image], [data-card-content]").forEach((el) => {
          (el as HTMLElement).style.viewTransitionName = "";
        });
      }

      function initCardTransitions() {
        document.querySelectorAll("[data-product-card]").forEach((card) => {
          card.addEventListener("click", () => {
            const slug = (card as HTMLElement).dataset.slug ?? "";
            sessionStorage.setItem("lastProductSlug", slug);
            sessionStorage.setItem("catalogScrollY", window.scrollY.toString());
            setCardTransition(slug);
          });
        });
      }

      // ── Antes de swap: marcar dirección ───────────────────────────────────
      document.addEventListener("astro:before-swap", () => {
        document.documentElement.dataset.navDirection = isBackNav ? "back" : "forward";
      });

      // ── After swap: filtro catálogo + scroll ──────────────────────────────
      document.addEventListener("astro:after-swap", () => {
        const filterCat = new URLSearchParams(window.location.search).get("categoria");

        if (isBackNav) {
          const savedScrollY = parseInt(sessionStorage.getItem("catalogScrollY") ?? "0", 10);
          sessionStorage.removeItem("catalogScrollY");

          document.querySelectorAll<HTMLElement>("[data-card-wrapper]").forEach((wrapper) => {
            const show = !filterCat || wrapper.dataset.category === filterCat;
            wrapper.style.display = show ? "" : "none";
          });

          window.scrollTo(0, savedScrollY);

          const slug = sessionStorage.getItem("lastProductSlug");
          if (slug) setCardTransition(slug);
          return;
        }

        document.querySelectorAll<HTMLElement>("[data-card-wrapper]").forEach((wrapper) => {
          const show = !filterCat || wrapper.dataset.category === filterCat;
          wrapper.style.display = show ? "" : "none";
        });

        const slug = sessionStorage.getItem("lastProductSlug");
        if (slug) setCardTransition(slug);
      });

      // ── Page load ─────────────────────────────────────────────────────────
      document.addEventListener("astro:page-load", () => {
        clearCardTransitions();
        delete document.documentElement.dataset.navDirection;
        isBackNav = false;

        const slugMatch = window.location.pathname.match(/\/catalogo\/([^/]+)/);
        if (slugMatch) sessionStorage.setItem("lastProductSlug", slugMatch[1]);

        handleScroll();
        initCardTransitions();
      });
    </script>
  </body>
</html>
