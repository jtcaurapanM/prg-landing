---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/catalog/ProductCard.astro';
import { products } from '../../data/products';
import { CATEGORY_LABELS, CATEGORY_DESCRIPTIONS, type CategorySlug } from '../../data/categories';

const categories = Object.entries(CATEGORY_LABELS) as [CategorySlug, string][];

const sortedProducts = [...products].sort((a, b) => {
  if (a.featured && !b.featured) return -1;
  if (!a.featured && b.featured) return 1;
  return 0;
});
---

<BaseLayout
  title="Catálogo · PRG Inversiones"
  description="Catálogo completo de productos de impresión: papelería corporativa, grandes formatos, packaging y más."
>
  <section data-gpu-fix class="bg-brand-surface border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <span class="text-xs font-semibold uppercase tracking-widest text-brand-orange-text">Catálogo</span>
      <h1 id="catalog-title" class="mt-2 text-3xl sm:text-4xl font-bold text-brand-black">
        Todos los productos
      </h1>
      <p id="catalog-desc" class="mt-3 text-gray-500 max-w-xl">
        Catálogo completo de productos de impresión: papelería corporativa, grandes formatos, packaging y más.
      </p>
    </div>
  </section>

  <section data-gpu-fix class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Filtros de categoría -->
    <div class="flex flex-wrap gap-2 mb-10">
      <button
        data-filter-btn
        data-filter-category=""
        class="px-4 py-2 rounded-full text-sm font-semibold border transition-colors bg-white text-gray-600 border-gray-200 cursor-pointer"
      >
        Todos
      </button>
      {categories.map(([slug, label]) => (
        <button
          data-filter-btn
          data-filter-category={slug}
          class="px-4 py-2 rounded-full text-sm font-semibold border transition-colors bg-white text-gray-600 border-gray-200 cursor-pointer"
        >
          {label}
        </button>
      ))}
    </div>

    <!-- Grid de productos — todos renderizados, filtrado en cliente -->
    <div
      id="catalog-grid"
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"
      style="transition: opacity 150ms ease"
    >
      {sortedProducts.map((product) => (
        <div data-card-wrapper data-category={product.category}>
          <ProductCard product={product} />
        </div>
      ))}
    </div>

    <p id="catalog-empty" class="hidden text-center py-24 text-gray-600 text-lg">
      No hay productos en esta categoría aún.
    </p>

  </section>

  <!--
    Tailwind safelist — clases usadas sólo en JS.
    bg-brand-black border-brand-black
  -->

  <script define:vars={{ categoryLabels: CATEGORY_LABELS, categoryDescriptions: CATEGORY_DESCRIPTIONS }}>
    function applyFilter(category, skipAnimation = false) {
      const grid = document.getElementById('catalog-grid');
      if (!grid) return;

      const doFilter = () => {
        let visible = 0;

        document.querySelectorAll('[data-card-wrapper]').forEach((wrapper) => {
          const show = !category || wrapper.dataset.category === category;
          wrapper.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        // Estado vacío
        const emptyEl = document.getElementById('catalog-empty');
        if (emptyEl) emptyEl.classList.toggle('hidden', visible > 0);

        // Botones activos
        document.querySelectorAll('[data-filter-btn]').forEach((btn) => {
          const btnCat = btn.dataset.filterCategory;
          const isActive = btnCat === (category ?? '');

          btn.classList.remove(
            'bg-brand-black', 'border-brand-black',
            'bg-brand-orange', 'border-brand-orange',
            'text-white',
            'bg-white', 'text-gray-600', 'border-gray-200'
          );

          if (isActive) {
            btn.classList.add('bg-brand-black', 'border-brand-black', 'text-white');
          } else {
            btn.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
          }
        });

        // Título y descripción
        const titleEl = document.getElementById('catalog-title');
        const descEl  = document.getElementById('catalog-desc');
        if (titleEl) {
          titleEl.textContent = category ? categoryLabels[category] : 'Todos los productos';
        }
        if (descEl) {
          descEl.textContent = category
            ? (categoryDescriptions[category] ?? `Explora nuestra línea de ${categoryLabels[category].toLowerCase()}. Solicita cotización sin compromiso.`)
            : 'Catálogo completo de productos de impresión: papelería corporativa, grandes formatos, packaging y más.';
        }

        if (!skipAnimation) grid.style.opacity = '1';
      };

      if (skipAnimation) {
        // Carga inicial o navegación con View Transition: los productos ya están
        // filtrados por astro:after-swap en BaseLayout. Solo actualizamos
        // botones, título y descripción sin tocar la opacidad del grid.
        doFilter();
      } else {
        // Click en filtro: fade out → filtrar → fade in
        grid.style.opacity = '0';
        setTimeout(doFilter, 150);
      }
    }

    function initCatalogFilter() {
      // define:vars produce un script inline que re-ejecuta en cada visita.
      // Usamos window para persistir el AbortController entre re-ejecuciones
      // y evitar que los botones de filtro acumulen click listeners.
      if (window.__catalogCtrl) window.__catalogCtrl.abort();
      const ctrl = new AbortController();
      window.__catalogCtrl = ctrl;
      const signal = ctrl.signal;

      // Leer categoría de la URL
      const params   = new URLSearchParams(window.location.search);
      const category = params.get('categoria') || null;
      // skipAnimation=true: los productos ya fueron filtrados en astro:after-swap
      // antes de que la página fuera visible. Solo sincronizamos el estado UI.
      applyFilter(category, true);

      // Click en filtros
      document.querySelectorAll('[data-filter-btn]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const cat = btn.dataset.filterCategory || null;
          applyFilter(cat);

          // Actualizar URL sin recargar la página
          const url = new URL(window.location.href);
          if (cat) {
            url.searchParams.set('categoria', cat);
          } else {
            url.searchParams.delete('categoria');
          }
          // Preservar history.state de Astro — si se pasa null se borra el
          // estado interno que Astro necesita para el View Transition de vuelta.
          history.replaceState(history.state, '', url.toString());
        }, { signal });
      });
    }

    // Inicializar en cada carga (View Transitions incluido)
    document.addEventListener('astro:page-load', initCatalogFilter);
  </script>

</BaseLayout>
