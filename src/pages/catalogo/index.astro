---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/catalog/ProductCard.astro';
import { products } from '../../data/products';
import { CATEGORY_LABELS, type CategorySlug } from '../../data/categories';

const categoryParam = Astro.url.searchParams.get('categoria') as CategorySlug | null;

const filtered = categoryParam
  ? products.filter((p) => p.category === categoryParam)
  : products;

const categories = Object.entries(CATEGORY_LABELS) as [CategorySlug, string][];

const pageTitle = categoryParam
  ? `${CATEGORY_LABELS[categoryParam]} · Catálogo`
  : 'Catálogo';

const pageDesc = categoryParam
  ? `Explora nuestra línea de ${CATEGORY_LABELS[categoryParam].toLowerCase()}. Solicita cotización sin compromiso.`
  : 'Catálogo completo de productos de impresión: papelería corporativa, grandes formatos, packaging y más.';
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <div class="bg-[#F8F8F6] border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <span class="text-xs font-semibold uppercase tracking-widest text-[#F4622A]">Catálogo</span>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold text-[#101820]">
        {categoryParam ? CATEGORY_LABELS[categoryParam] : 'Todos los productos'}
      </h1>
      <p class="mt-3 text-gray-500 max-w-xl">{pageDesc}</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Category filter -->
    <div class="flex flex-wrap gap-2 mb-10">
      <a
        href="/catalogo"
        class={`px-4 py-2 rounded-full text-sm font-semibold border transition-colors ${!categoryParam ? 'bg-[#101820] text-white border-[#101820]' : 'bg-white text-gray-600 border-gray-200 hover:border-[#F4622A] hover:text-[#F4622A]'}`}
      >
        Todos
      </a>
      {categories.map(([slug, label]) => (
        <a
          href={`/catalogo?categoria=${slug}`}
          class={`px-4 py-2 rounded-full text-sm font-semibold border transition-colors ${categoryParam === slug ? 'bg-[#F4622A] text-white border-[#F4622A]' : 'bg-white text-gray-600 border-gray-200 hover:border-[#F4622A] hover:text-[#F4622A]'}`}
        >
          {label}
        </a>
      ))}
    </div>

    <!-- Product grid -->
    {filtered.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {filtered.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    ) : (
      <div class="text-center py-24 text-gray-400">
        <p class="text-lg">No hay productos en esta categoría aún.</p>
      </div>
    )}

  </div>
</BaseLayout>
