---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import ProductCard from '../../components/catalog/ProductCard.astro';
import { products } from '../../data/products';
import { CATEGORY_LABELS } from '../../data/categories';

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const categoryLabel = CATEGORY_LABELS[product.category];
const relatedProducts = products
  .filter((p) => p.category === product.category && p.slug !== product.slug)
  .slice(0, 3);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  brand: { '@type': 'Brand', name: 'PRG Inversiones' },
  image: product.images[0],
  category: categoryLabel,
};
---

<BaseLayout
  title={`${product.name} · Catálogo PRG Inversiones`}
  description={`${product.shortDesc} Solicita cotización sin compromiso.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- Breadcrumb -->
  <div class="bg-[#F8F8F6] border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#F4622A] transition-colors">Inicio</a>
        <span>/</span>
        <a href="/catalogo" class="hover:text-[#F4622A] transition-colors">Catálogo</a>
        <span>/</span>
        <a href={`/catalogo?categoria=${product.category}`} class="hover:text-[#F4622A] transition-colors">{categoryLabel}</a>
        <span>/</span>
        <span class="text-[#101820] font-medium">{product.name}</span>
      </nav>
    </div>
  </div>

  <!-- Product detail -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- Image -->
      <div>
        <div class="rounded-2xl overflow-hidden bg-gray-50 aspect-[4/3]">
          <img
            src={product.images[0]}
            alt={product.name}
            width="800"
            height="600"
            loading="eager"
            class="w-full h-full object-cover"
          />
        </div>
        {product.images.length > 1 && (
          <div class="grid grid-cols-4 gap-3 mt-4">
            {product.images.slice(1).map((img, i) => (
              <div class="rounded-lg overflow-hidden aspect-square bg-gray-50">
                <img src={img} alt={`${product.name} - imagen ${i + 2}`} width="200" height="200" loading="lazy" class="w-full h-full object-cover" />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div>
        <div class="flex flex-wrap gap-2 mb-4">
          <Badge text={categoryLabel} variant="gray" />
          {product.featured && <Badge text="Destacado" variant="orange" />}
          {product.fscEligible && <Badge text="FSC Disponible" variant="fsc" />}
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold text-[#101820] mb-4">{product.name}</h1>
        <p class="text-gray-600 leading-relaxed mb-8">{product.description}</p>

        <!-- Specs -->
        <div class="mb-8">
          <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-4">Especificaciones</h2>
          <ul class="space-y-2">
            {product.specs.map((spec) => (
              <li class="flex items-start gap-3 text-sm text-gray-700">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[#F4622A] shrink-0"></span>
                {spec}
              </li>
            ))}
          </ul>
        </div>

        <!-- Materials -->
        {product.materials.length > 0 && (
          <div class="mb-8">
            <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-4">Materiales disponibles</h2>
            <div class="flex flex-wrap gap-2">
              {product.materials.map((mat) => (
                <span class="px-3 py-1.5 bg-gray-100 text-gray-600 text-xs font-medium rounded-md">{mat}</span>
              ))}
            </div>
          </div>
        )}

        <!-- FSC note -->
        {product.fscEligible && (
          <div class="p-4 bg-green-50 border border-green-200 rounded-xl mb-8">
            <div class="flex items-start gap-3">
              <span class="text-green-600 mt-0.5">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </span>
              <div>
                <div class="text-sm font-semibold text-green-800 mb-0.5">Disponible con certificación FSC</div>
                <p class="text-xs text-green-700">Este producto puede fabricarse con insumos de cadena de custodia certificada FSC C143583.</p>
              </div>
            </div>
          </div>
        )}

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={`/contacto?producto=${encodeURIComponent(product.name)}`}
            class="flex-1 inline-flex items-center justify-center px-6 py-3.5 bg-[#F4622A] text-white font-bold rounded-md hover:bg-[#d9521f] transition-colors"
          >
            Cotizar este producto
          </a>
          <a
            href={`https://wa.me/56900000000?text=Hola%2C%20me%20gustar%C3%ADa%20cotizar%3A%20${encodeURIComponent(product.name)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3.5 border-2 border-[#25D366] text-[#25D366] font-semibold rounded-md hover:bg-[#25D366] hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>

    <!-- Related products -->
    {relatedProducts.length > 0 && (
      <div class="mt-24">
        <h2 class="text-2xl font-bold text-[#101820] mb-8">Otros productos en {categoryLabel}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedProducts.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
