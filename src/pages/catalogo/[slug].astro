---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import ProductCard from '../../components/catalog/ProductCard.astro';
import QuoteForm from '../../components/forms/QuoteForm.astro';
import { products } from '../../data/products';
import { CATEGORY_LABELS } from '../../data/categories';

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const SHOW_SPECS     = false;
const SHOW_MATERIALS = false;

const { product } = Astro.props;
const categoryLabel = CATEGORY_LABELS[product.category];
const relatedProducts = products
  .filter((p) => p.category === product.category && p.slug !== product.slug)
  .slice(0, 3);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  brand: { '@type': 'Brand', name: 'PRG Inversiones' },
  image: product.images[0],
  category: categoryLabel,
};
---

<BaseLayout
  title={`${product.name} · Catálogo PRG Inversiones`}
  description={`${product.shortDesc} Solicita cotización sin compromiso.`}
>
  {/* Sanitizar </script> dentro del JSON-LD para prevenir XSS (PERF-07) */}
  <script type="application/ld+json" set:html={JSON.stringify(structuredData).replace(/<\//g, '<\\/')} />

  <!-- Breadcrumb -->
  <section data-gpu-fix class="bg-brand-surface border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-brand-orange transition-colors">Inicio</a>
        <span>/</span>
        <a href="/catalogo" class="hover:text-brand-orange transition-colors">Catálogo</a>
        <span>/</span>
        <a href={`/catalogo?categoria=${product.category}`} class="hover:text-brand-orange transition-colors">{categoryLabel}</a>
        <span>/</span>
        <span class="text-brand-black font-medium">{product.name}</span>
      </nav>
    </div>
  </section>

  <!-- Product detail -->
  <section data-gpu-fix class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- ── Carousel ──────────────────────────────────────────────────────── -->
      <div
        id="product-carousel"
        transition:name={`product-img-${product.slug}`}
        data-gpu-fix
        class="relative rounded-2xl overflow-hidden bg-gray-50 aspect-[4/3] select-none"
        role="region"
        aria-label={`Galería de imágenes de ${product.name}`}
      >
        <!-- Track (slides horizontales) -->
        <div
          id="carousel-track"
          class="flex h-full"
          style="will-change:transform;transition:transform 380ms cubic-bezier(0.4,0,0.2,1);"
        >
          <!-- Slide 1: Image optimizada (LCP) -->
          <div class="flex-none w-full h-full">
            <Image
              src={product.images[0]}
              alt={product.name}
              width={800}
              height={600}
              loading="eager"
              fetchpriority="high"
              class="w-full h-full object-cover"
            />
          </div>

          <!-- Slides 2+: img directo (CDN Unsplash, no precargado por Astro) -->
          {product.images.slice(1).map((img, i) => (
            <div class="flex-none w-full h-full">
              <img
                src={img}
                alt={`${product.name} — vista ${i + 2}`}
                width="800"
                height="600"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
              />
            </div>
          ))}
        </div>

        {product.images.length > 1 && (
          <>
            <!-- Botón anterior -->
            <button
              id="carousel-prev"
              type="button"
              aria-label="Imagen anterior"
              class="absolute left-3 top-1/2 -translate-y-1/2 z-10 w-9 h-9 flex items-center justify-center rounded-full bg-white/85 backdrop-blur-sm shadow-md text-brand-black hover:bg-white hover:scale-110 transition-all duration-200"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
              </svg>
            </button>

            <!-- Botón siguiente -->
            <button
              id="carousel-next"
              type="button"
              aria-label="Imagen siguiente"
              class="absolute right-3 top-1/2 -translate-y-1/2 z-10 w-9 h-9 flex items-center justify-center rounded-full bg-white/85 backdrop-blur-sm shadow-md text-brand-black hover:bg-white hover:scale-110 transition-all duration-200"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
              </svg>
            </button>

            <!-- Contador (esquina superior derecha) -->
            <div
              class="absolute top-3 right-3 z-10 pointer-events-none bg-black/40 text-white text-xs font-medium px-2.5 py-1 rounded-full backdrop-blur-sm"
              aria-live="polite"
            >
              <span id="carousel-counter">1 / {product.images.length}</span>
            </div>

            <!-- Dots (centro inferior) -->
            <div
              class="absolute bottom-3 left-1/2 -translate-x-1/2 z-10 flex gap-1.5 pointer-events-none"
              aria-hidden="true"
            >
              {product.images.map((_, i) => (
                <span
                  data-carousel-dot={i}
                  class="block rounded-full"
                  style={`width:7px;height:7px;background:white;transition:opacity 250ms,transform 250ms;opacity:${i === 0 ? '1' : '0.4'};transform:${i === 0 ? 'scale(1.25)' : 'scale(1)'}`}
                />
              ))}
            </div>
          </>
        )}
      </div>
      <!-- ── /Carousel ─────────────────────────────────────────────────────── -->

      <!-- Info -->
      <div transition:name={`product-info-${product.slug}`} data-gpu-fix>
        <div class="flex flex-wrap gap-2 mb-4">
          <Badge text={categoryLabel} variant="gray" />
          {product.featured && <Badge text="Destacado" variant="orange" />}
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold text-brand-black mb-4">
          {product.name}
        </h1>
        <p class="text-gray-600 leading-relaxed mb-8">{product.description}</p>

        <!-- Specs -->
        {SHOW_SPECS && (
          <div class="mb-8">
            <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-4">Especificaciones</h2>
            <ul class="space-y-2">
              {product.specs.map((spec) => (
                <li class="flex items-start gap-3 text-sm text-gray-700">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-brand-orange shrink-0"></span>
                  {spec}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Materials -->
        {SHOW_MATERIALS && product.materials.length > 0 && (
          <div class="mb-8">
            <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-4">Materiales disponibles</h2>
            <div class="flex flex-wrap gap-2">
              {product.materials.map((mat) => (
                <span class="px-3 py-1.5 bg-gray-100 text-gray-600 text-xs font-medium rounded-md">{mat}</span>
              ))}
            </div>
          </div>
        )}

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3">
          <button
            id="open-quote-dialog"
            type="button"
            class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-brand-orange text-white font-bold rounded-md hover:bg-brand-orange-dark transition-colors"
            aria-haspopup="dialog"
            aria-controls="quote-dialog"
          >
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Cotizar este producto
          </button>
        </div>
      </div>
    </div>

    <!-- Related products -->
    {relatedProducts.length > 0 && (
      <div class="mt-24">
        <h2 class="text-2xl font-bold text-brand-black mb-8">Otros productos en {categoryLabel}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedProducts.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<!-- ── Dialog modal de cotización ─────────────────────────────────────────── -->
<dialog id="quote-dialog" aria-modal="true" aria-labelledby="dialog-title">
  <!-- Sticky header -->
  <div class="sticky top-0 z-10 flex items-center justify-between px-6 sm:px-8 py-4 bg-white border-b border-gray-100">
    <div>
      <h2 id="dialog-title" class="font-bold text-brand-black text-base">Solicitar cotización</h2>
      <p class="text-xs text-gray-400 mt-0.5 truncate max-w-xs">{product.name}</p>
    </div>
    <button
      type="button"
      id="close-quote-dialog"
      class="flex items-center justify-center w-8 h-8 rounded-full text-gray-400 hover:text-brand-black hover:bg-gray-100 transition-colors"
      aria-label="Cerrar formulario"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  <!-- Form content -->
  <div class="px-6 sm:px-8 py-6">
    <QuoteForm productName={product.name} dialogMode={true} />
    <p class="mt-5 text-center text-xs text-gray-400">
      ¿Prefieres escribir directo?
      <a href="mailto:contacto@prg.cl" class="text-brand-orange hover:underline font-medium">contacto@prg.cl</a>
    </p>
  </div>
</dialog>

<style>
  #quote-dialog {
    border: none;
    padding: 0;
    border-radius: 1.25rem;
    background: white;
    margin: auto;
    width: calc(100% - 2rem);
    max-width: 820px;
    max-height: 96dvh;
    overflow-y: auto;
    overflow-x: hidden;
    box-shadow:
      0 0 0 1px rgba(0,0,0,0.04),
      0 25px 60px -12px rgba(0,0,0,0.28);
  }
  #quote-dialog::backdrop {
    background: rgba(16, 24, 32, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  #quote-dialog::backdrop {
    animation: lightbox-backdrop-in 260ms ease both;
  }
  #quote-dialog.is-closing::backdrop {
    animation: lightbox-backdrop-out 200ms ease both;
  }
  #quote-dialog.is-open {
    animation: dialog-in 380ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  #quote-dialog.is-closing {
    animation: dialog-out 200ms cubic-bezier(0.4, 0, 1, 1) both;
  }
</style>

<script>
  let _slugCtrl: AbortController | null = null;

  // ── Carrusel de imágenes del producto ────────────────────────────────────
  function initCarousel(signal: AbortSignal) {
    const carousel = document.getElementById('product-carousel');
    const track    = document.getElementById('carousel-track') as HTMLElement | null;
    if (!carousel || !track) return;

    const slides  = track.querySelectorAll<HTMLElement>(':scope > div');
    const total   = slides.length;
    if (total <= 1) return;

    const dots    = carousel.querySelectorAll<HTMLElement>('[data-carousel-dot]');
    const counter = document.getElementById('carousel-counter');
    let current   = 0;
    let autoTimer: ReturnType<typeof setTimeout> | null = null;

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        d.style.opacity   = i === current ? '1'    : '0.4';
        d.style.transform = i === current ? 'scale(1.25)' : 'scale(1)';
      });
      if (counter) counter.textContent = `${current + 1} / ${total}`;
    }

    function scheduleAuto() {
      if (autoTimer) clearTimeout(autoTimer);
      if (!signal.aborted) {
        autoTimer = setTimeout(() => { goTo(current + 1); scheduleAuto(); }, 4500);
      }
    }

    function resetAuto() { scheduleAuto(); }

    // Botones de navegación
    document.getElementById('carousel-prev')?.addEventListener('click', () => { goTo(current - 1); resetAuto(); }, { signal });
    document.getElementById('carousel-next')?.addEventListener('click', () => { goTo(current + 1); resetAuto(); }, { signal });

    // Swipe táctil
    let touchX = 0;
    carousel.addEventListener('touchstart', (e: TouchEvent) => { touchX = e.touches[0].clientX; }, { signal, passive: true });
    carousel.addEventListener('touchend', (e: TouchEvent) => {
      const delta = e.changedTouches[0].clientX - touchX;
      if (Math.abs(delta) > 40) { goTo(current + (delta < 0 ? 1 : -1)); resetAuto(); }
    }, { signal });

    // Teclado (flechas izq/der cuando el carrusel está enfocado)
    carousel.setAttribute('tabindex', '0');
    carousel.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft')  { goTo(current - 1); resetAuto(); e.preventDefault(); }
      if (e.key === 'ArrowRight') { goTo(current + 1); resetAuto(); e.preventDefault(); }
    }, { signal });

    // Pausar auto-play al pasar el cursor
    carousel.addEventListener('mouseenter', () => { if (autoTimer) { clearTimeout(autoTimer); autoTimer = null; } }, { signal });
    carousel.addEventListener('mouseleave', resetAuto, { signal });

    goTo(0);
    scheduleAuto();
  }

  // ── Modal de cotización ──────────────────────────────────────────────────
  function initQuoteDialog(signal: AbortSignal) {
    const openBtn  = document.getElementById('open-quote-dialog');
    const dialog   = document.getElementById('quote-dialog')       as HTMLDialogElement | null;
    const closeBtn = document.getElementById('close-quote-dialog') as HTMLButtonElement  | null;

    if (!openBtn || !dialog) return;

    function openDialog() {
      if (dialog!.open) return;
      dialog!.showModal();
      requestAnimationFrame(() => dialog!.classList.add('is-open'));
      document.body.style.overflow = 'hidden';
    }

    function closeDialog() {
      dialog!.classList.remove('is-open');
      dialog!.classList.add('is-closing');
      let done = false;
      const finish = () => {
        if (done) return;
        done = true;
        dialog!.classList.remove('is-closing');
        dialog!.close();
        document.body.style.overflow = '';
      };
      dialog!.addEventListener('animationend', finish, { once: true });
      setTimeout(finish, 250);
    }

    openBtn.addEventListener('click', openDialog, { signal });
    closeBtn?.addEventListener('click', closeDialog, { signal });
    dialog.addEventListener('click', (e: MouseEvent) => {
      if (e.target === dialog) closeDialog();
    }, { signal });
    dialog.addEventListener('cancel', (e: Event) => {
      e.preventDefault();
      closeDialog();
    }, { signal });
  }

  // ── Inicialización por página ────────────────────────────────────────────
  function initPage() {
    _slugCtrl?.abort();
    _slugCtrl = new AbortController();
    const { signal } = _slugCtrl;
    initCarousel(signal);
    initQuoteDialog(signal);
  }

  document.addEventListener('astro:page-load', initPage);

  document.addEventListener('astro:before-swap', () => {
    _slugCtrl?.abort();
    const dialog = document.getElementById('quote-dialog') as HTMLDialogElement | null;
    if (dialog?.open) {
      dialog.classList.remove('is-closing', 'is-open');
      dialog.close();
    }
    document.body.style.overflow = '';
  });
</script>
