---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Sobre PRG Inversiones · Imprenta certificada FSC Chile"
  description="Desde 2011 fabricamos comunicación visual sostenible con certificación FSC C143583. Conoce nuestra historia, valores y propuesta de valor diferenciada."
>
  <!-- Header -->
  <section data-gpu-fix class="bg-[#101820] text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span
        class="text-xs font-semibold uppercase tracking-widest text-[#F4622A]"
        >Sobre nosotros</span
      >
      <h1 class="mt-3 text-4xl sm:text-5xl font-bold max-w-2xl leading-tight">
        Más que una imprenta.<br />
        <span class="text-[#F4622A]">Una propuesta diferente.</span>
      </h1>
      <p class="mt-5 text-white/60 max-w-xl leading-relaxed">
        Fundada en 2011, PRG Inversiones integra sustentabilidad real,
        tecnología industrial y un equipo especializado para resolver
        necesidades complejas de comunicación visual.
      </p>
    </div>
  </section>

  <!-- Historia -->
  <section data-gpu-fix class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl font-bold text-[#101820] mb-6">
            Desde 2011, innovando con propósito
          </h2>
          <p class="text-gray-600 leading-relaxed mb-5">
            Inversiones PRG SpA nació el año 2011 y desde el inicio hemos
            innovado continuamente para resolver las necesidades de nuestros
            clientes, buscando siempre una propuesta de valor sustentable y
            amigable con el medio ambiente.
          </p>
          <p class="text-gray-600 leading-relaxed mb-5">
            La producción de elementos de comunicación visual, dada la alta
            rotación de los mismos, debe fabricarse con insumos que provoquen el
            menor impacto ambiental al momento de cambiarlos. Por eso, uno de
            nuestros primeros objetivos fue trabajar con proveedores que nos
            aseguraran absoluta responsabilidad en la cadena de custodia
            forestal en cada etapa del proceso productivo. Hoy contamos con la
            certificación FSC C143583.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Entendiendo la necesidad de nuestros clientes de comunicar y
            mantener una constante presencia, contamos con soluciones y
            tecnologías de impresión, corte, grabado y terminación que, junto a
            nuestro equipo humano, son capaces de plasmar en cualquier tipo de
            objeto y material el mensaje o imagen que se quiera entregar.
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden aspect-video">
          <Image
            src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=800&q=80&fm=webp"
            alt="Equipo de trabajo PRG Inversiones"
            width={800}
            height={450}
            loading="lazy"
            decoding="async"
            sizes="(max-width: 1024px) 100vw, 50vw"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Valores -->
  <section data-gpu-fix class="py-24 bg-[#F8F8F6]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold text-[#101820]">
          Tres pilares que nos definen
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          [
            {
              icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
              title: "Sustentabilidad real",
              desc: "Certificación FSC C143583 vigente. No es marketing: es una auditoría de cadena de custodia que garantiza el origen responsable de nuestros insumos.",
            },
            {
              icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
              title: "Soluciones integrales",
              desc: "Contamos con tecnologías de impresión, corte, grabado y terminación capaces de plasmar en cualquier tipo de objeto y material el mensaje o imagen que se quiera entregar.",
            },
            {
              icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
              title: "Asesoría personalizada",
              desc: "Estamos siempre disponibles para asesorarte y recomendarte la solución óptima para tus requerimientos. Cada proyecto recibe atención directa de nuestro equipo.",
            },
          ].map((v) => (
            <div data-gpu-fix class="bg-white rounded-2xl p-8 border border-gray-100">
              <div class="text-[#F4622A] mb-5">
                <Fragment set:html={v.icon} />
              </div>
              <h3 class="font-bold text-[#101820] text-xl mb-3">{v.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{v.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FSC Detail -->
  <section data-gpu-fix class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <div
          class="flex w-fit items-baseline gap-2 bg-green-50 border border-green-200 rounded-full px-4 py-2 mb-6"
        >
          <span class="block w-2 h-2 rounded-full bg-green-500 shrink-0 mb-px"></span>
          <span
            class="block text-xs font-semibold text-green-700 uppercase tracking-wide leading-none"
            >Certificación FSC C143583</span
          >
        </div>
        <h2 class="text-3xl font-bold text-[#101820] mb-6">
          ¿Qué significa que seamos FSC?
        </h2>
        <p class="text-gray-600 leading-relaxed mb-8">
          FSC (Forest Stewardship Council) es la certificación internacional más
          reconocida en gestión forestal responsable. El número <strong
            >C143583</strong
          > identifica nuestra certificación de cadena de custodia, que garantiza
          que los materiales de papel y cartón que utilizamos han sido trazados desde
          el bosque hasta tu producto final.
        </p>
        <p class="text-gray-600 leading-relaxed mb-10">
          Para empresas con políticas de compra responsable, contratar con un
          proveedor certificado FSC es un requisito o un diferencial
          competitivo. Al trabajar con PRG, puedes comunicar ese compromiso a
          tus propios clientes con respaldo documental.
        </p>

        <!-- SVG del certificado: unificado en todos los dispositivos.
             Aspect-ratio A4 (595/842) define la altura sin necesitar altura fija. -->
        <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm mb-6">
          <div class="relative w-full bg-white aspect-[595/842]">
            <object
              data="/Certificado-FSC-2023.svg"
              type="image/svg+xml"
              class="block w-full h-full"
              aria-hidden="true"
            ></object>
            <!-- Overlay: captura clicks (object tiene su propio browsing context) -->
            <button
              data-nosotros-cert-open
              class="absolute inset-0 cursor-zoom-in group"
              aria-label="Ver certificado FSC C143583 ampliado"
            >
              <!-- Mobile: siempre visible · Desktop: aparece al hover -->
              <span class="absolute bottom-3 right-3 flex items-center gap-1.5 bg-black/50 text-white text-xs font-medium px-3 py-1.5 rounded-full pointer-events-none transition-opacity md:opacity-0 md:group-hover:opacity-100">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
                Ampliar
              </span>
            </button>
          </div>
        </div>

        <a
          href="/Certificado-FSC-2023.pdf"
          download
          class="inline-flex items-center gap-2 px-6 py-3 bg-[#101820] text-white text-sm font-semibold rounded-md hover:bg-[#1e2d3d] transition-colors"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
          </svg>
          Descargar certificado PDF
        </a>
      </div>
    </div>
  </section>

  <!-- Lightbox certificado FSC -->
  <dialog
    id="nosotros-cert-dialog"
    aria-label="Certificado FSC C143583 ampliado"
    aria-modal="true"
  >
    <div class="flex items-center justify-center w-full h-full p-4 sm:p-8">
      <div class="cert-panel relative w-full max-w-xl bg-white rounded-2xl overflow-hidden shadow-2xl flex flex-col" style="max-height: 90svh">
        <button
          data-nosotros-cert-close
          class="absolute top-3 right-3 z-10 w-9 h-9 flex items-center justify-center rounded-full bg-black/30 text-white hover:bg-black/60 transition-colors"
          aria-label="Cerrar"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
        <!-- SVG: ocupa el espacio disponible; viewBox escala para caber (sin corte) -->
        <div class="flex-1 min-h-0">
          <object
            data="/Certificado-FSC-2023.svg"
            type="image/svg+xml"
            class="block w-full h-full"
            aria-label="Certificado FSC C143583 — PRG Inversiones"
          ></object>
        </div>
        <!-- Footer: siempre visible en la parte inferior -->
        <div class="shrink-0 px-5 py-4 border-t border-gray-100 flex items-center justify-between gap-4 bg-white">
          <div>
            <p class="text-sm font-semibold text-[#101820]">Certificado FSC C143583</p>
            <p class="text-xs text-gray-400 mt-0.5">PRG Inversiones</p>
          </div>
          <a
            href="/Certificado-FSC-2023.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="shrink-0 inline-flex items-center gap-1.5 px-4 py-2 bg-[#101820] text-white text-xs font-semibold rounded-md hover:bg-[#1e2d3d] transition-colors"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Descargar PDF
          </a>
        </div>
      </div>
    </div>
  </dialog>
</BaseLayout>

<script>
  // AbortController scoped to each page load: prevents listener accumulation
  // across View Transitions navigations.
  let _nosotrosCtrl: AbortController | null = null;

  function initNosotrosCertLightbox() {
    _nosotrosCtrl?.abort();
    _nosotrosCtrl = new AbortController();
    const { signal } = _nosotrosCtrl;

    const dialog = document.getElementById("nosotros-cert-dialog") as HTMLDialogElement | null;
    if (!dialog) return;

    function closeNosotrosDialog() {
      const panel = dialog!.querySelector<HTMLElement>(".cert-panel");
      if (!panel) { dialog!.close(); return; }
      dialog!.classList.remove("is-open");
      dialog!.classList.add("is-closing");
      panel.addEventListener("animationend", () => {
        dialog!.classList.remove("is-closing");
        dialog!.close();
      }, { once: true });
    }

    document.querySelectorAll("[data-nosotros-cert-open]").forEach((btn) => {
      btn.addEventListener("click", () => {
        if (!dialog!.open) {
          dialog!.showModal();
          // rAF needed: Safari doesn't fire CSS animations on [open] children;
          // adding the class one frame later ensures the animation triggers.
          requestAnimationFrame(() => dialog!.classList.add("is-open"));
        }
      }, { signal });
    });

    dialog.querySelector("[data-nosotros-cert-close]")?.addEventListener("click", closeNosotrosDialog, { signal });

    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) closeNosotrosDialog();
    }, { signal });

    dialog.addEventListener("cancel", (e) => {
      e.preventDefault();
      closeNosotrosDialog();
    }, { signal });
  }

  document.addEventListener("astro:page-load", initNosotrosCertLightbox);
</script>
