---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteForm from '../components/forms/QuoteForm.astro';

const productParam = Astro.url.searchParams.get('producto') ?? '';
---

<BaseLayout
  title="Cotización · PRG Inversiones"
  description="Solicita una cotización personalizada para tu proyecto de impresión corporativa. Respondemos en 24 horas hábiles."
>

  <div class="bg-[#F8F8F6] border-b border-gray-100 py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-semibold uppercase tracking-widest text-[#F4622A]">Cotización</span>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold text-[#101820]">Hablemos de tu proyecto</h1>
      <p class="mt-3 text-gray-500 max-w-xl">
        Cuéntanos qué necesitas y te enviamos una propuesta a medida en menos de 24 horas hábiles.
        Sin costo ni compromiso.
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Sidebar info -->
      <div class="lg:col-span-1">
        <h2 class="font-bold text-[#101820] text-xl mb-6">¿Por qué elegirnos?</h2>

        <div class="space-y-6 mb-10">
          {[
            { icon: '⏱', title: 'Respuesta en 24h', desc: 'Revisamos cada consulta y respondemos con una propuesta real.' },
            { icon: '📋', title: 'Sin compromiso', desc: 'La cotización es sin costo. Si no te convence, no hay ningún problema.' },
            { icon: '🌿', title: 'Certificación FSC', desc: 'Tu pedido puede incluir insumos con cadena de custodia certificada.' },
            { icon: '🏭', title: 'Producción propia', desc: 'Sin intermediarios. Controlamos el proceso de principio a fin.' },
          ].map((item) => (
            <div class="flex gap-4">
              <span class="text-2xl mt-0.5">{item.icon}</span>
              <div>
                <div class="font-semibold text-[#101820] text-sm mb-1">{item.title}</div>
                <div class="text-sm text-gray-500 leading-relaxed">{item.desc}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="p-5 bg-[#101820] rounded-xl text-white">
          <div class="text-sm font-semibold mb-2">¿Consulta urgente?</div>
          <p class="text-xs text-white/60 mb-4">Si tu proyecto tiene un plazo ajustado, escríbenos directamente.</p>
          <a
            href="https://wa.me/56900000000?text=Hola%2C%20tengo%20una%20consulta%20urgente%20sobre%20un%20proyecto%20de%20impresi%C3%B3n."
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 justify-center px-4 py-2.5 bg-[#25D366] text-white text-sm font-semibold rounded-md hover:bg-[#1ebe5c] transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Escribir por WhatsApp
          </a>
        </div>
      </div>

      <!-- Form -->
      <div class="lg:col-span-2 bg-white border border-gray-100 rounded-2xl p-8 shadow-sm">
        <QuoteForm productName={productParam} />
      </div>

    </div>
  </div>

</BaseLayout>
