---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteForm from '../components/forms/QuoteForm.astro';

const productParam = Astro.url.searchParams.get('producto') ?? '';
---

<BaseLayout
  title="Cotización · PRG Inversiones"
  description="Solicita una cotización personalizada para tu proyecto de impresión corporativa. Respondemos en 24 horas hábiles."
>

  <div class="bg-[#F8F8F6] border-b border-gray-100 py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-semibold uppercase tracking-widest text-[#F4622A]">Cotización</span>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold text-[#101820]">Hablemos de tu proyecto</h1>
      <p class="mt-3 text-gray-500 max-w-xl">
        Cuéntanos qué necesitas y te enviamos una propuesta a medida en menos de 24 horas hábiles.
        Sin costo ni compromiso.
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Sidebar info -->
      <div class="lg:col-span-1">
        <h2 class="font-bold text-[#101820] text-xl mb-6">¿Por qué elegirnos?</h2>

        <div class="space-y-6 mb-10">
          {[
            { icon: '⏱', title: 'Respuesta en 24h', desc: 'Revisamos cada consulta y respondemos con una propuesta real.' },
            { icon: '📋', title: 'Sin compromiso', desc: 'La cotización es sin costo. Si no te convence, no hay ningún problema.' },
            { icon: '🌿', title: 'Certificación FSC', desc: 'Tu pedido puede incluir insumos con cadena de custodia certificada.' },
            { icon: '🏭', title: 'Producción propia', desc: 'Sin intermediarios. Controlamos el proceso de principio a fin.' },
          ].map((item) => (
            <div class="flex gap-4">
              <span class="text-2xl mt-0.5">{item.icon}</span>
              <div>
                <div class="font-semibold text-[#101820] text-sm mb-1">{item.title}</div>
                <div class="text-sm text-gray-500 leading-relaxed">{item.desc}</div>
              </div>
            </div>
          ))}
        </div>

      </div>

      <!-- Form -->
      <div class="lg:col-span-2 bg-white border border-gray-100 rounded-2xl p-8 shadow-sm">
        <QuoteForm productName={productParam} />
      </div>

    </div>
  </div>

</BaseLayout>
