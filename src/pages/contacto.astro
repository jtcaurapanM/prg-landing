---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteForm from '../components/forms/QuoteForm.astro';

const productParam = Astro.url.searchParams.get('producto') ?? '';
---

<BaseLayout
  title="Cotización · PRG Inversiones"
  description="Solicita una cotización personalizada para tu proyecto de impresión corporativa. Respondemos en 24 horas hábiles."
>

  <section class="bg-[#F8F8F6] border-b border-gray-100 py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-semibold uppercase tracking-widest text-[#F4622A]">Cotización</span>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold text-[#101820]">Hablemos de tu proyecto</h1>
      <p class="mt-3 text-gray-500 max-w-xl">
        Cuéntanos qué necesitas y te enviamos una propuesta a medida en menos de 24 horas hábiles.
        Sin costo ni compromiso.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Sidebar info -->
      <div class="lg:col-span-1 lg:sticky lg:top-[calc(var(--navbar-height,88px)+2rem)] lg:self-start">
        <h2 class="font-bold text-[#101820] text-xl mb-6">¿Por qué elegirnos?</h2>

        <div class="space-y-6 mb-10">
          <!-- Respuesta en 24h -->
          <div class="flex gap-4">
            <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-[#F4622A]/10 text-[#F4622A] shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-[#101820] text-sm mb-1">Respuesta en 24h</div>
              <div class="text-sm text-gray-500 leading-relaxed">Revisamos cada consulta y respondemos con una propuesta real.</div>
            </div>
          </div>
          <!-- Sin compromiso -->
          <div class="flex gap-4">
            <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-[#F4622A]/10 text-[#F4622A] shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-[#101820] text-sm mb-1">Sin compromiso</div>
              <div class="text-sm text-gray-500 leading-relaxed">La cotización es sin costo. Si no te convence, no hay ningún problema.</div>
            </div>
          </div>
          <!-- Certificación FSC -->
          <div class="flex gap-4">
            <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-[#F4622A]/10 text-[#F4622A] shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-[#101820] text-sm mb-1">Certificación FSC</div>
              <div class="text-sm text-gray-500 leading-relaxed">Tu pedido puede incluir insumos con cadena de custodia certificada.</div>
            </div>
          </div>
          <!-- Producción propia -->
          <div class="flex gap-4">
            <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-[#F4622A]/10 text-[#F4622A] shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-[#101820] text-sm mb-1">Producción propia</div>
              <div class="text-sm text-gray-500 leading-relaxed">Sin intermediarios. Controlamos el proceso de principio a fin.</div>
            </div>
          </div>
        </div>

      </div>

      <!-- Form -->
      <div class="lg:col-span-2 bg-white border border-gray-100 rounded-2xl p-8 shadow-sm">
        <QuoteForm productName={productParam} />
      </div>

    </div>
  </section>

</BaseLayout>
