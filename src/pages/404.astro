---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Página no encontrada · PRG Inversiones"
  description="La página que buscas no existe o fue movida. Vuelve al inicio o explora nuestro catálogo."
>
  <section class="bg-brand-black text-white min-h-[80dvh] flex items-center">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">

      <!-- Número 404 -->
      <div
        class="text-[clamp(6rem,20vw,12rem)] font-bold leading-none text-brand-orange select-none"
        aria-hidden="true"
      >
        404
      </div>

      <h1 class="mt-4 text-3xl sm:text-4xl font-bold text-white">
        Página no encontrada
      </h1>
      <p class="mt-4 text-white/60 max-w-md mx-auto leading-relaxed">
        El enlace puede estar roto o la página fue removida.<br />
        Prueba volviendo al inicio o explorando el catálogo.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center px-8 py-4 bg-brand-orange text-white font-bold rounded-md hover:bg-brand-orange-dark transition-colors"
        >
          Ir al inicio
        </a>
        <a
          href="/catalogo"
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-md hover:border-white hover:bg-white/10 transition-colors"
        >
          Ver catálogo
        </a>
      </div>

      <!-- Separator -->
      <div class="mt-16 pt-8 border-t border-white/10">
        <p class="text-sm text-white/30">
          PRG Inversiones · Comunicación visual industrial ·
          <a href="/contacto" class="text-white/50 hover:text-brand-orange transition-colors underline underline-offset-2">
            Contáctanos
          </a>
        </p>
      </div>

    </div>
  </section>
</BaseLayout>
